@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/bob(self)bob> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://www.example.org/mia/bob(bob)bob.(bob)> ;
    owl:imports <http://www.example.org/mia/alice(alice)bob.(bob)> ;
    dc:date "2026-06-13"^^xsd:date ;
    owl:versionInfo "Version 1.0.5 - flatten directory structure"@en ;
    rdfs:label "Bob Johnson - Selfness"@en ;
    rdfs:comment """Bob Johnson's selfness — the essential individuality and sense of selfhood from which
                    context-specific Personas (whonesses) are correlated.

                    Correlated Personas:
                    - :Bob_Johnson-as-known-by-alice (05-bob(bob)alice.(bob).ttl)   — colleague persona (Alice's view)
                    - :Bob_Johnson-Bob                   (06-bob(bob)bob.(bob).ttl)    — Bob persona (self-asserted, dyad with #5)
                    - :Bob_Johnson-BHS                   (09-bob(bob)bob.(bhs).ttl)    — BHS member persona
                    - :Alice_Walker-ByBob                (04-alice(alice)bob.(bob).ttl) — Alice's persona as asserted by Bob (hasMember)"""@en .


#################################################################
#    Bob Johnson - Person Instance
#################################################################

:Bob_Johnson-Self rdf:type owl:NamedIndividual ,
                           <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Bob Johnson's selfness — the central identity individual."@en ;

    persona:hasPersona :Bob_Johnson-Bob ;
    persona:hasPersona :Bob_Johnson-as-known-by-alice ;
    persona:hasPersona :Bob_Johnson-BHS ;
    <http://purl.obolibrary.org/obo/BFO_0000115> :Alice_Walker-ByBob .  # has member part → Alice's persona asserted by Bob
