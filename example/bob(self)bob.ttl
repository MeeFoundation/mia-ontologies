@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/bob(self)bob> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://www.example.org/mia/bob(bob)bob> ;
    owl:imports <http://www.example.org/mia/alice(bob)bob.(bob)> ;
    dc:date "2026-06-13"^^xsd:date ;
    owl:versionInfo "Version 2.0.1 - rename :Alice_Walker to :Self"@en ;
    rdfs:label "Bob Johnson - Selfness"@en ;
    rdfs:comment """Bob Johnson's selfness — the central identity individual. The same IRI (:Bob_Johnson)
                    is used in every context file about Bob; each file is a named-graph slice.

                    Bob's context files (all use :Bob_Johnson):
                    - 05-bob(bob)alice.ttl  — Alice's notes about Bob
                    - 06-bob(bob)bob.ttl    — Bob's self-asserted persona (dyad with 05)
                    - 09-bob(bhs)bob.ttl    — BHS member persona

                    Also links to (via BFO_0000115 hasMember):
                    - :Self in 04-alice(bob)bob.ttl — Alice as asserted by Bob"""@en .


#################################################################
#    Bob Johnson - Person Instance
#################################################################

:Bob_Johnson rdf:type owl:NamedIndividual ,
                      persona:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Bob Johnson's selfness — the central identity individual."@en ;

    <http://purl.obolibrary.org/obo/BFO_0000115> :Self .  # has member part → Alice as asserted by Bob
