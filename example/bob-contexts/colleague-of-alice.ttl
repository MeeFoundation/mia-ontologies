@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/bob-colleague-of-alice> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-12"^^xsd:date ;
    owl:versionInfo "Version 1.0.0 - initial"@en ;
    context:contextCategory context:Colleagues ;
    context:assertedBy identity:Self ;
    context:subject identity:Individual ;
    context:name "Colleague of Alice" ;
    rdfs:label "Bob Johnston - Colleague of Alice Persona"@en ;
    rdfs:comment """Bob Johnston's colleague whoness — representing him in the context of his
                    colleague relationship with Alice Walker.
                    Referenced from Alice's colleagues social network in alice-contexts/colleagues.ttl."""@en .


#################################################################
#    Bob Johnston - Colleague of Alice Persona
#################################################################

:Bob_Johnston-Colleagues rdf:type owl:NamedIndividual ,
                                  persona:Persona ;
    rdfs:label "Bob Johnston (Colleagues)"@en ;
    rdfs:comment "Bob Johnston's persona in the context of his colleague relationship with Alice."@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → GivenName
        rdf:type cco:ent00000002 ;
        <https://purl.org/cco/ont00001765> "Bob"
    ] ;

    <https://purl.org/cco/ont00001879> [  # designated by → FamilyName
        rdf:type cco:ent00000004 ;
        <https://purl.org/cco/ont00001765> "Johnston"
    ] ;

    <http://purl.obolibrary.org/obo/BFO_0000196> :Bob_EmployeeOfAcme .  # bearer of → career role


#################################################################
#    Bob Johnston's Career Role
#################################################################

:Bob_EmployeeOfAcme rdf:type owl:NamedIndividual ;
    rdfs:label "Bob Johnston - Employee of Acme"@en ;
    rdfs:comment "Bob Johnston's role as an employee of Acme."@en .
