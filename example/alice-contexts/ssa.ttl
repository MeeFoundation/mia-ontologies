@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/ssa> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-01"^^xsd:date ;
    owl:versionInfo "Version 1.0.6 - add context:name"@en ;
    context:contextCategory context:Federal ;
    context:assertedBy identity:Self ;
    context:subject identity:Self ;
    context:name "Social Security Administration" ;
    rdfs:label "Alice Walker - SSA Persona"@en ;
    rdfs:comment """Alice Walker's SSA whoness — representing her in the context of her
                    Social Security Administration record.
                    Correlated from :Alice_Walker-Self in self.ttl.

                    SSN: 123-45-6788"""@en .


#################################################################
#    Alice Walker - SSA Persona
#################################################################

:Alice_Walker-SSA rdf:type owl:NamedIndividual ,
                           persona:Persona ;
    rdfs:label "Alice Walker (SSA)"@en ;
    rdfs:comment "Alice Walker's persona in the context of her Social Security Administration record."@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → SSN
        rdf:type cco:ent00000008 ;
        <https://purl.org/cco/ont00001765> "123-45-6788"
    ] .
