@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/family> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-01"^^xsd:date ;
    owl:versionInfo "Version 1.0.7 - update self.ttl ref to alice(self)alice.ttl"@en ;
    context:contextCategory context:Family ;
    context:assertedBy identity:Self ;
    context:subject identity:Self ;
    context:name "Family" ;
    rdfs:label "Alice Walker - Family Persona"@en ;
    rdfs:comment """Alice Walker's family whoness — representing her in the context of her
                    family relationships. Correlated from :Alice_Walker-Self in alice(self)alice.ttl."""@en .


#################################################################
#    Alice Walker - Family Persona
#################################################################

:Alice_Walker-Family rdf:type owl:NamedIndividual ,
                              persona:Persona ;
    rdfs:label "Alice Walker (Family)"@en ;
    rdfs:comment "Alice Walker's persona in the context of her family relationships."@en ;

    persona:hasSocialNetwork :Alice_Family_Network .


#################################################################
#    Alice's Family Social Network
#################################################################

:Alice_Family_Network rdf:type owl:NamedIndividual ,
                               cco:ont00001183 ;  # Social Network
    rdfs:label "Alice Walker's family connections"@en ;
    <http://purl.obolibrary.org/obo/BFO_0000115> :Paula_Walker-Family .  # has member part


#################################################################
#    Paula Walker - Family Persona
#################################################################

:Paula_Walker-Family rdf:type owl:NamedIndividual ,
                              persona:Persona ;
    rdfs:label "Paula Walker (Family)"@en ;
    rdfs:comment "Paula Walker's persona in the context of her family relationship with Alice."@en .
