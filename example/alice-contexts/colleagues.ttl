@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/colleagues> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-12"^^xsd:date ;
    owl:versionInfo "Version 1.0.12 - update Bob member reference to Bob_Johnson-Bob-colleague-of-alice"@en ;
    context:contextCategory context:Colleagues ;
    context:assertedBy identity:Self ;
    context:subject identity:Self ;
    context:name "Colleagues" ;
    rdfs:label "Alice Walker - Colleagues Persona"@en ;
    rdfs:comment """Alice Walker's colleagues whoness — representing her in the context of her
                    professional colleague relationships.
                    Correlated from :Alice_Walker-Self in self.ttl."""@en .


#################################################################
#    Alice Walker - Colleagues Persona
#################################################################

:Alice_Walker-Colleagues rdf:type owl:NamedIndividual ,
                                  persona:Persona ;
    rdfs:label "Alice Walker (Colleagues)"@en ;
    rdfs:comment "Alice Walker's persona in the context of her colleague relationships."@en ;

    persona:hasSocialNetwork :Alice_Colleagues_Network .


#################################################################
#    Alice's Colleagues Social Network
#################################################################

:Alice_Colleagues_Network rdf:type owl:NamedIndividual ,
                                   cco:ont00001183 ;  # Social Network
    rdfs:label "Alice Walker's colleagues connections"@en ;
    <http://purl.obolibrary.org/obo/BFO_0000115> :Paula_Walker-Colleagues ;  # has member part
    <http://purl.obolibrary.org/obo/BFO_0000115> :Bob_Johnson-Bob-colleague-of-alice .  # has member part
