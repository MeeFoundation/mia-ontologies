@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

# diagram label = 12

<http://www.example.org/mia/alice(att)alice> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-01"^^xsd:date ;
    owl:versionInfo "Version 1.0.10 - align ontology IRI with filename"@en ;
    context:contextCategory context:Company ;
    context:assertedBy identity:Self ;
    context:subject identity:Self ;
    context:name "AT&T" ;
    rdfs:label "Alice Walker - AT&T Persona"@en ;
    rdfs:comment """Alice Walker's AT&T whoness — representing her in the context of her
                    AT&T phone account. Correlated from :Alice_Walker-Self in alice(self)alice.ttl.

                    Phone: +15108149999"""@en .


#################################################################
#    Alice Walker - AT&T Persona
#################################################################

:Alice_Walker-ATT rdf:type owl:NamedIndividual ,
                           persona:Persona ;
    rdfs:label "Alice Walker (AT&T)"@en ;
    rdfs:comment "Alice Walker's persona in the context of her AT&T phone account."@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → Phone
        rdf:type cco:ent00000023 ;
        <https://purl.org/cco/ont00001765> "+15108149999" ;
        rdfs:comment "E.164 format (international standard)"@en
    ] .
