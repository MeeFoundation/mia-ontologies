@prefix : <http://www.example.org/mia#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/bhs-group> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/group> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-12"^^xsd:date ;
    owl:versionInfo "Version 1.0.2 - rename file to bhs(bhs)members.ttl"@en ;
    context:contextCategory context:Group ;
    context:assertedBy identity:Self ;
    context:subject identity:Group ;
    context:name "Boston Hub Society" ;
    rdfs:label "Boston Hub Society - Group"@en ;
    rdfs:comment """The Boston Hub Society group — a g:Group instance with members Alice Walker and Bob Johnson."""@en .


#################################################################
#    Boston Hub Society Group
#################################################################

:BHS_Group rdf:type owl:NamedIndividual ,
                    g:Group ;
    rdfs:label "Boston Hub Society"@en ;
    rdfs:comment "The Boston Hub Society group instance."@en ;
    <http://purl.obolibrary.org/obo/BFO_0000115> :Alice_Walker-BHS ;  # has member part
    <http://purl.obolibrary.org/obo/BFO_0000115> :Bob_Johnson-BHS .   # has member part
