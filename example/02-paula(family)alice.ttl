@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

# diagram label = 2

<http://www.example.org/mia/paula(family)alice> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-14"^^xsd:date ;
    owl:versionInfo "Version 2.0.0 - unified persona:Person IRI model; dyad moved to graph level"@en ;
    context:contextCategory context:Family ;
    context:assertedBy :Alice_Walker ;
    context:subject :Paula_Walker ;
    context:name "Family" ;
    context:dyad <http://www.example.org/mia/paula(family)paula> ;
    rdfs:label "Paula Walker - Alice's family member "@en ;
    rdfs:comment """What Alice states about Paula in the context of their family relationship.
                    Member of :Alice_Family_Network in alice(family)alice.ttl.
                    Shares IRI :Paula_Walker with paula(self)paula.ttl."""@en .


#################################################################
#    Paula Walker - Family Persona
#################################################################

:Paula_Walker rdf:type owl:NamedIndividual ,
               persona:Person ;
    rdfs:label "Paula Walker (Family)"@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → GivenName
        rdf:type cco:ent00000002 ;  # GivenName
        <https://purl.org/cco/ont00001765> "Paula"  # has text value
    ] ;

    <https://purl.org/cco/ont00001879> [  # designated by → FamilyName
        rdf:type cco:ent00000004 ;  # FamilyName
        <https://purl.org/cco/ont00001765> "Walker"  # has text value
    ] .
