@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/paula(self)paula> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://www.example.org/mia/paula(family)paula> ;
    dc:date "2026-06-12"^^xsd:date ;
    owl:versionInfo "Version 2.0.0 - unified persona:Person IRI model; remove hasPersona links"@en ;
    rdfs:label "Paula Walker - Selfness"@en ;
    rdfs:comment """Paula Walker's selfness — the central identity individual. The same IRI (:Paula_Walker)
                    is used in every context file about Paula; each file is a named-graph slice.

                    Paula's context files (all use :Paula_Walker):
                    - 01-paula(acme)alice.ttl   — Paula as Alice's Acme colleague (Alice-asserted)
                    - 02-paula(family)alice.ttl — Paula's family persona (Alice-asserted)
                    - 03-paula(family)paula.ttl — Paula's family persona (self-asserted, dyad with 02)"""@en .


#################################################################
#    Paula Walker - Person Instance
#################################################################

:Paula_Walker rdf:type owl:NamedIndividual ,
                       persona:Person ;
    rdfs:label "Paula Walker"@en ;
    rdfs:comment "Paula Walker's selfness — the central identity individual."@en .
