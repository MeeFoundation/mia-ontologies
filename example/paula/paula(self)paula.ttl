@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/paula-self> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://www.example.org/mia/paula-family-paula> ;
    dc:date "2026-06-12"^^xsd:date ;
    owl:versionInfo "Version 1.0.2 - update hasPersona to Paula_Walker-FamilySelf"@en ;
    rdfs:label "Paula Walker - Selfness"@en ;
    rdfs:comment """Paula Walker's selfness — the essential individuality and sense of selfhood from which
                    context-specific Personas (whonesses) are correlated.

                    Correlated Personas:
                    - :Paula_Walker-FloridaBirthCertificate (paula-contexts/paula(fl-birth-cert)alice.ttl)    — legal name record
                    - :Paula_Walker-Colleagues              (paula-contexts/paula(Paula)alice.(acme).ttl)     — colleague persona
                    - :Paula_Walker-Family                  (paula-contexts/paula(paula)alice.(family).ttl)   — family persona (Alice's view)
                    - :Paula_Walker-FamilySelf              (paula-contexts/paula(paula)paula.(family).ttl)   — family persona (self-asserted, dyad with above)"""@en .


#################################################################
#    Paula Walker - Person Instance
#################################################################

:Paula_Walker-Self rdf:type owl:NamedIndividual ,
                            <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Paula Walker"@en ;
    rdfs:comment "Paula Walker's selfness — the central identity individual."@en ;

    persona:hasPersona :Paula_Walker-FloridaBirthCertificate ;
    persona:hasPersona :Paula_Walker-Family ;
    persona:hasPersona :Paula_Walker-FamilySelf ;
    persona:hasPersona :Paula_Walker-Colleagues .
