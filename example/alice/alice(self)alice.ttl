@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://www.example.org/mia/citibank> ;
    owl:imports <http://www.example.org/mia/boston> ;
    owl:imports <http://www.example.org/mia/paradise> ;
    owl:imports <http://www.example.org/mia/family> ;
    owl:imports <http://www.example.org/mia/colleagues> ;
    owl:imports <http://www.example.org/mia/att> ;
    owl:imports <http://www.example.org/mia/ssa> ;
    owl:imports <http://www.example.org/mia/google> ;
    owl:imports <http://www.example.org/mia/texas-birth-certificate> ;
    owl:imports <http://www.example.org/mia/florida-birth-certificate> ;
    owl:imports <http://www.example.org/mia/belongings> ;
    owl:imports <http://www.example.org/mia/bhs> ;
    owl:imports <http://www.example.org/mia/bob-bhs> ;
    owl:imports <http://www.example.org/mia/bhs-group> ;
    owl:imports <http://www.example.org/mia/paula-colleague-of-alice> ;
    owl:imports <http://www.example.org/mia/bob-colleague-of-alice> ;
    owl:imports <http://www.example.org/mia/bob> ;
    owl:imports <http://www.example.org/mia/paula-family> ;
    owl:imports <http://www.example.org/mia/paula-self> ;
    dc:date "2026-06-12"^^xsd:date ;
    owl:versionInfo "Version 3.0.58 - move Paula_Walker-Self to paula(self)paula.ttl"@en ;
    rdfs:label "Alice Walker - Selfness"@en ;
    rdfs:comment """Alice Walker's selfness — the essential individuality and sense of selfhood from which
                    context-specific Personas (whonesses) are correlated.

                    Person Details:
                    - Height: 68 inches
                    - Eye Color: Blue
                    - Hair Color: Grey
                    - Mother: Paula Walker

                    Correlated Personas:
                    - :Alice_Walker-Citibank  (alice(citibank)alice.ttl)  — Citibank financial relationship
                    - :Alice_Walker-Boston    (alice(boston)alice.ttl)    — Boston residence (2020-2025)
                    - :Alice_Walker-Paradise  (alice(paradise)alice.ttl)  — Paradise residence (2025-present)
                    - :Alice_Walker-Family      (alice(family)alice.ttl)      — family relationships
                    - :Alice_Walker-Colleagues (alice(colleagues)alice.ttl) — colleague relationships
                    - :Alice_Walker-ATT        (alice(att)alice.ttl)        — AT&T phone account
                    - :Alice_Walker-SSA        (alice(ssa)alice.ttl)        — Social Security Administration
                    - :Alice_Walker-Google                (alice(google)alice.ttl)               — Google account (Gmail)
                    - :Alice_Walker-TexasBirthCertificate (alice(tx-birth-cert)alice.ttl) — legal name record
                    - :Alice_Walker-Possessions           (belongings.ttl)              — wallet, driver's license, health insurance card
                    - :Alice_Walker-BHS                  (alice(bhs)alice.ttl)                     — BHS group profile (address, phone, email)
                    - :Alice_Walker-Bob                  (alice(bob)alice.ttl)                     — 1:1 relationship with Bob Johnson

                    Bob Johnson (BHS member):
                    - :Bob_Johnson-BHS                   (bob-contexts/bob(bob)bob.(bhs).ttl)        — BHS member persona

                    Boston Hub Society (group):
                    - :BHS_Group                         (bhs-contexts/bhs(bhs)members.ttl)  — BHS group instance with social network

                    Bob Johnston (colleagues):
                    - :Bob_Johnston-Colleagues           (bob-contexts/bob(bob)alice.(bob).ttl) — colleague persona

                    Paula Walker (Alice's mother):
                    - :Paula_Walker-Self                    (paula/paula(self)paula.ttl)                      — selfness
                    - :Paula_Walker-FloridaBirthCertificate (paula-contexts/paula(fl-birth-cert)alice.ttl)    — legal name record
                    - :Paula_Walker-Colleagues              (paula-contexts/paula(Paula)alice.(acme).ttl)     — colleague persona
                    - :Paula_Walker-Family                  (paula-contexts/paula(paula)alice.(family).ttl)   — family persona (Alice's view)"""@en .


#################################################################
#    Alice Walker - Person Instance
#################################################################

###  Person: Alice Walker
:Alice_Walker-Self rdf:type owl:NamedIndividual ,
                       <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Alice Walker"@en ;
    rdfs:comment "Alice Walker's selfness — the central identity individual."@en ;

    # PREFERRED NAME (goes by across all contexts)
    <https://purl.org/cco/ont00001879> [  # designated by → AlternateName
        rdf:type cco:ent00000006 ;  # AlternateName
        <https://purl.org/cco/ont00001765> "Alice Walker" ;  # has text value
        rdfs:comment "Name she goes by professionally and socially"@en
    ] ;

    # PHYSICAL CHARACTERISTICS
    
    <http://purl.obolibrary.org/obo/BFO_0000196> :Alice_Height ;               # bearer of → Height quality
    <http://purl.obolibrary.org/obo/BFO_0000196> :Alice_Height_Measurement ;  # bearer of → Height measurement ICE

    <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Eye Color
        rdf:type cco:ent00000040 ;  # Blue Eye Color
        rdfs:comment "Eye color: Blue"@en
    ] ;

    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Scalp Hair
        rdf:type cco:ont00000058 ;  # Scalp Hair
        <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Hair Color
            rdf:type cco:ont00000026 ;  # Hair Color
            <https://purl.org/cco/ont00001765> "Grey" ;  # has text value
            rdfs:comment "Hair color: Grey"@en
        ]
    ] ;

    # FAMILY RELATIONSHIPS

    cco:ont00001780 :Paula_Walker-Self ;  # has mother

    # CORRELATED PERSONAS (whonesses)

    persona:hasPersona :Alice_Walker-Citibank ;
    persona:hasPersona :Alice_Walker-Boston ;
    persona:hasPersona :Alice_Walker-Paradise ;
    persona:hasPersona :Alice_Walker-Family ;
    persona:hasPersona :Alice_Walker-Colleagues ;
    persona:hasPersona :Alice_Walker-ATT ;
    persona:hasPersona :Alice_Walker-SSA ;
    persona:hasPersona :Alice_Walker-Google ;
    persona:hasPersona :Alice_Walker-TexasBirthCertificate ;
    persona:hasPersona :Alice_Walker-Possessions ;
    persona:hasPersona :Alice_Walker-BHS .



#################################################################
#    Height Measurement
#################################################################

:Alice_Height rdf:type owl:NamedIndividual ,
                       <https://purl.org/cco/ont00000967> ;  # Height (CCO Quality)
    rdfs:label "Alice Walker's height"@en .

:Alice_Height_Measurement rdf:type owl:NamedIndividual ,
                                   <https://purl.org/cco/ont00001022> ;  # Ratio Measurement ICE
    <https://purl.org/cco/ont00001983> :Alice_Height ;    # is a ratio measurement of
    <https://purl.org/cco/ont00001863> <https://purl.org/cco/ont00001677> ;  # uses measurement unit: Inch
    <https://purl.org/cco/ont00001769> "68"^^xsd:decimal .  # has decimal value



