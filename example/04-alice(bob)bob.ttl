@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

# diagram label = 4

<http://www.example.org/mia/alice(bob)bob> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-13"^^xsd:date ;
    owl:versionInfo "Version 2.0.1 - rename :Alice_Walker to :Self"@en ;
    context:contextCategory context:Person ;
    context:assertedBy :Bob_Johnson ;
    context:subject :Self ;
    context:name "Bob" ;
    context:dyad <http://www.example.org/mia/alice(bob)alice> ;
    rdfs:label "Alice Walker - in her relationship with Bob)"@en ;
    rdfs:comment """What Bob states about Alice in the context of their (1:1) relationship
                    Paired (dyad) with alice(bob)alice.ttl (#17) 
                    Shares IRI :Self with alice(self)alice.ttl."""@en .


#################################################################
#    Alice Walker - Bob Persona (Bob's view)
#################################################################

:Self rdf:type owl:NamedIndividual ,
               persona:Person ;
    rdfs:label "Alice Walker by Bob"@en ;

    <https://purl.org/cco/ont00001917> [  # described by → Person Note
        rdf:type cco:ent00000048 ;
        <https://purl.org/cco/ont00001765> "Favorite drink: pepsi"
    ] .
