@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

# diagram label = 1

<http://www.example.org/mia/paula(acme)alice> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    dc:date "2026-06-14"^^xsd:date ;
    owl:versionInfo "Version 1.0.9 - contextCategory changed from Colleague to Employee"@en ;
    context:contextCategory context:Employee ;
    context:assertedBy identity:Self ;
    context:subject identity:Individual ;
    context:name "Acme" ;
    rdfs:label "Paula Walker - Colleague of Alice"@en ;
    rdfs:comment """What Alice says about Paula in the context of them both working at Acme.
                    Correlated from :Paula_Walker-Self in alice(self)alice.ttl."""@en .


#################################################################
#    Paula Walker - Colleague of Alice Persona
#################################################################

:Paula_Walker-as-colleague-of-Alice-at-Acme rdf:type owl:NamedIndividual ,
                                  persona:Persona ;
    rdfs:label "Paula Walker (Acme)"@en .

