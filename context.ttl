@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/pdn-identity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/context> .

<http://mee.foundation/ontologies/context> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/context/1.0.1> ;
    dc:date "2026-06-01"^^xsd:date ;
    owl:imports <http://mee.foundation/ontologies/pdn-identity> ;
    owl:versionInfo "Version 1.0.38 - update import IRI to pdn-identity"@en ;
    rdfs:label "Context Ontology"@en ;
    rdfs:comment """Context Ontology for the Mee Identity Agent.

                    Defines controlled vocabularies for classifying context ontology files:
                    - contextCategory: the kind of relationship a context file represents
                    - assertedBy: the identity asserting the data (an identity:PDNidentity subclass)
                    - subject: whose identity the file describes (an identity:PDNidentity subclass)

                    Peer of persona.ttl and pdn-identity.ttl; imported directly by each context file."""@en .


#################################################################
#    Annotation Properties for Context File Classification
#################################################################

context:contextCategory rdf:type owl:AnnotationProperty ;
    rdfs:label "context type"@en ;
    rdfs:comment """Tags a context ontology (file) with the kind of relationship it represents —
                    e.g. context:Company, context:Federal, context:Municipality.
                    Applied to the ontology IRI, not to the Person individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range context:ContextCategory .

context:assertedBy rdf:type owl:AnnotationProperty ;
    rdfs:label "asserted by"@en ;
    rdfs:comment """Tags a context ontology (file) with the individual identity making the assertion —
                    an individual of identity:PDNidentity (e.g. identity:Self, identity:Organization).
                    Applied to the ontology IRI, not to the Person individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range identity:PDNidentity .

context:subject rdf:type owl:AnnotationProperty ;
    rdfs:label "subject"@en ;
    rdfs:comment """Tags a context ontology (file) with whose identity it describes —
                    an individual of identity:PDNidentity (e.g. identity:Self, or a named individual of identity:Individual).
                    Applied to the ontology IRI, not to the Person individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range identity:PDNidentity .

context:name rdf:type owl:AnnotationProperty ;
    rdfs:label "name"@en ;
    rdfs:comment """A human-readable name for this context ontology (file).
                    Applied to the ontology IRI, not to the Person individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range xsd:string .

context:template rdf:type owl:AnnotationProperty ;
    rdfs:label "template"@en ;
    rdfs:comment """Tags a context ontology (file) with the persona template type that applies to it.
                    Value is one of the persona:PersonaTemplate subclasses
                    (persona:BirthCertificate, persona:JSContactCard, persona:DriversLicense).
                    Used to select the appropriate per-template SHACL shapes file for validation.
                    Applied to the ontology IRI."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range <http://mee.foundation/ontologies/persona#PersonaTemplate> .

context:dyad rdf:type owl:AnnotationProperty ;
    rdfs:label "dyad"@en ;
    rdfs:comment """Tags a context ontology (file) with the IRI of its dyad partner context —
                    the reciprocal context about the same relationship asserted by the other party.
                    Applied to the ontology IRI. Must be symmetric: if A dyad B then B dyad A."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range owl:Ontology .


#################################################################
#    Context Categories
#    Subclasses are used as values for the context:contextCategory
#    annotation property on ontology IRIs (context files)
#################################################################

context:ContextCategory rdf:type owl:Class ;
    rdfs:label "ContextCategory"@en ;
    rdfs:comment """Controlled vocabulary for categories of contexts.
                    Used as the value of context:contextCategory on ontology IRIs."""@en .

#################################################################
#    MultiPerson Contexts and subclasses
#################################################################

context:MultiPerson rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "MultiPerson"@en ;
    rdfs:comment "Contexts involving interactions with multiple people or groups."@en .

context:Group rdf:type owl:Class ;
    rdfs:subClassOf context:MultiPerson ;
    rdfs:label "Group"@en ;
    rdfs:comment "Interactions with a formal or informal group of people."@en .


#################################################################
#    SinglePerson Contexts and subclasses
#################################################################

context:SinglePerson rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "SinglePerson"@en ;
    rdfs:comment "Contexts involving interactions with a single entity — company, government, or person."@en .

#################################################################
#    c:Person Contexts and subclasses
#################################################################

context:Person rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Person"@en ;
    rdfs:comment "Interactions with all kinds of people."@en .

context:FamilyMember rdf:type owl:Class ;
    rdfs:subClassOf context:Person ;
    rdfs:label "FamilyMember"@en ;
    rdfs:comment "Interactions with a family member."@en .

context:Friend rdf:type owl:Class ;
    rdfs:subClassOf context:Person ;
    rdfs:label "Friend"@en ;
    rdfs:comment "Interactions with friends."@en .

context:Consultant rdf:type owl:Class ;
    rdfs:subClassOf context:Person ;
    rdfs:label "Consultant"@en ;
    rdfs:comment "Interactions with consultants who provide services."@en .

#################################################################
#    c:Work Contexts and subclasses
#################################################################

context:Work rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Work"@en ;
    rdfs:comment "Professional roles, employment history, and career relationships."@en .

context:Employee rdf:type owl:Class ;
    rdfs:subClassOf context:Work ;
    rdfs:label "Employee"@en ;
    rdfs:comment "Related to being an employee."@en .

context:Contributor rdf:type owl:Class ;
    rdfs:subClassOf context:Work ;
    rdfs:label "Contributor"@en ;
    rdfs:comment "Related to contributing to initiatives started or led by others."@en .

context:Creator rdf:type owl:Class ;
    rdfs:subClassOf context:Work ;
    rdfs:label "Creator"@en ;
    rdfs:comment "Related to being a creator, inventor, founder, author of something."@en .


#################################################################
#    c:Company Contexts and subclasses
#################################################################

context:Company rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Company"@en ;
    rdfs:comment "Relationship with a specific company, bank, or other institution."@en .

context:FinancialServices rdf:type owl:Class ;
    rdfs:subClassOf context:Company ;
    rdfs:label "FinancialServices"@en ;
    rdfs:comment "Relationship with a bank or other financial services institution."@en .

context:Healthcare rdf:type owl:Class ;
    rdfs:subClassOf context:Company ;
    rdfs:label "Healthcare"@en ;
    rdfs:comment "Relationship with a healthcare provider or health insurance company."@en .

#################################################################
#    c:Finances Context (personal finance, no institution)
#################################################################

context:Finances rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Finances"@en ;
    rdfs:comment "Information about personal finances not related to any interactions with banks, financial institutions or government agencies."@en .

#################################################################
#    c:Health Context (personal wellness, no provider)
#################################################################

context:Health rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Health"@en ;
    rdfs:comment "Personal health and wellness information not related to any specific healthcare provider."@en .

#################################################################
#    c:Event Contexts and subclasses
#################################################################    

context:Event rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Event"@en ;
    rdfs:comment "Participation in or relationship to a specific event."@en .

context:Meeting rdf:type owl:Class ;
    rdfs:subClassOf context:Event ;
    rdfs:label "Meeting"@en ;
    rdfs:comment "A meeting or appointment."@en .

context:Conference rdf:type owl:Class ;
    rdfs:subClassOf context:Event ;
    rdfs:label "Conference"@en ;
    rdfs:comment "A conference or professional gathering."@en .

context:Party rdf:type owl:Class ;
    rdfs:subClassOf context:Event ;
    rdfs:label "Party"@en ;
    rdfs:comment "A party or social celebration."@en .

#################################################################
#    c:Government Contexts and subclasses
################################################################# 

context:Government rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Government"@en ;
    rdfs:comment "Government-issued credentials, tax records, and civic relationships."@en .

context:Federal rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "Federal"@en ;
    rdfs:comment "Federal government context (e.g. passport, federal tax records)."@en .

context:State rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "State"@en ;
    rdfs:comment "State government context (e.g. driver's license, state tax records)."@en .

context:Municipality rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "Municipality"@en ;
    rdfs:comment "Municipal government context (e.g. local permits, library card)."@en .

#################################################################
#    c:Note Contexts and subclasses
################################################################# 

context:Note rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Note"@en ;
    rdfs:comment "Notes about topics not covered by any other context category."@en .

context:Learning rdf:type owl:Class ;
    rdfs:subClassOf context:Note ;
    rdfs:label "Learning"@en ;
    rdfs:comment "Knowledge gained from personal experience"@en .

#################################################################
#    c:Possession Contexts and subclasses
################################################################# 

context:Possession rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Possession"@en ;
    rdfs:comment "Owned assets, property, vehicles, and other possessions."@en .

context:Automobile rdf:type owl:Class ;
    rdfs:subClassOf context:Possession ;
    rdfs:label "Automobile"@en ;
    rdfs:comment "Owning and maintaining an automobile."@en .

context:Pet rdf:type owl:Class ;
    rdfs:subClassOf context:Possession ;
    rdfs:label "Pet"@en ;
    rdfs:comment "Taking care of pets."@en .

context:Dwelling rdf:type owl:Class ;
    rdfs:subClassOf context:Possession ;
    rdfs:label "Dwelling"@en ;
    rdfs:comment "Owning or renting a home or other dwelling."@en .

#################################################################
#    c:Project Contexts and subclasses
################################################################# 

context:Project rdf:type owl:Class ;
    rdfs:subClassOf context:SinglePerson ;
    rdfs:label "Project"@en ;
    rdfs:comment "Involvement in a specific project or initiative."@en .
