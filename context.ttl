@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/pdn-identity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/context> .

<http://mee.foundation/ontologies/context> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/context/1.0.1> ;
    dc:date "2026-06-01"^^xsd:date ;
    owl:imports <http://mee.foundation/ontologies/pdn-identity> ;
    owl:versionInfo "Version 1.0.61 - add context:MarriagePartner as subclass of People"@en ;
    rdfs:label "Context Ontology"@en ;
    rdfs:comment """Context and Category Ontology for the Mee Identity Agent"""@en .


#################################################################
#    Annotation Properties for Context DataBook Classification
#################################################################

context:category rdf:type owl:AnnotationProperty ;
    rdfs:label "context type"@en ;
    rdfs:comment """Annotates a DataBook named graph of its containing c:Category —
                    e.g. context:Companies, context:Federal, context:Municipality.
                    Applied to the named graph IRI, not to the Person individual."""@en ;
    rdfs:range context:Category .

context:assertedBy rdf:type owl:AnnotationProperty ;
    rdfs:label "asserted by"@en ;
    rdfs:comment """Annotates a DataBook named graph with the individual identity making the assertion —
                    an individual of identity:PDNidentifier (e.g. identity:Self, identity:Organization).
                    Applied to the named graph IRI, not to the Person individual."""@en ;
    rdfs:range identity:PDNidentifier .

context:subject rdf:type owl:AnnotationProperty ;
    rdfs:label "subject"@en ;
    rdfs:comment """Annotates a DataBook named graph with whose identity it describes —
                    an individual of identity:PDNidentifier (e.g. identity:Self, or a named individual of identity:Individual).
                    Applied to the named graph IRI, not to the Person individual."""@en ;
    rdfs:range identity:PDNidentifier .

context:template rdf:type owl:AnnotationProperty ;
    rdfs:label "template"@en ;
    rdfs:comment """Annotates a DataBook named graph with the persona template type that applies to it.
                    Value is one of the persona:PersonaTemplate subclasses
                    (persona:BirthCertificate, persona:JSContactCard, persona:DriversLicense).
                    Used to select the appropriate per-template SHACL shapes file for validation.
                    Applied to the named graph IRI."""@en ;
    rdfs:range <http://mee.foundation/ontologies/persona#PersonaTemplate> .

#################################################################
#    Context (DataBook)
#################################################################

context:Context rdf:type owl:Class ;
    rdfs:label "Context"@en ;
    rdfs:comment "A context DataBook — a named graph containing identity data about a person in a specific relationship or situation."@en .

context:SBS-Context rdf:type owl:Class ;
    rdfs:subClassOf context:Context ;
    rdfs:label "SBS-Context"@en ;
    rdfs:comment "Self-by-Self: a DataBook whose subject is :Self and whose assertedBy is :Self."@en .

context:OBS-Context rdf:type owl:Class ;
    rdfs:subClassOf context:Context ;
    rdfs:label "OBS-Context"@en ;
    rdfs:comment "Other-by-Self: a DataBook whose subject is another person/org/group and whose assertedBy is :Self."@en .

context:OBO-Context rdf:type owl:Class ;
    rdfs:subClassOf context:Context ;
    rdfs:label "OBO-Context"@en ;
    rdfs:comment "Other-by-Other: a DataBook whose subject is another person/org/group and whose assertedBy is also another person/org/group."@en .

context:SBO-Context rdf:type owl:Class ;
    rdfs:subClassOf context:Context ;
    rdfs:label "SBO-Context"@en ;
    rdfs:comment "Self-by-Other: a DataBook whose subject is :Self and whose assertedBy is another person/org/group."@en .

context:about-by rdf:type owl:AnnotationProperty ;
    rdfs:label "about-by"@en ;
    rdfs:comment "Classifies a DataBook named graph by the combination of subject and assertedBy: one of context:SBS-Context, context:OBS-Context, context:OBO-Context, or context:SBO-Context."@en .


#################################################################
#    Category
#################################################################

context:Category rdf:type owl:Class ;
    rdfs:label "Category"@en ;
    rdfs:comment """Controlled vocabulary for categories of contexts.
                    Used as the value of context:category on DataBook named graph IRIs."""@en .


context:Predefined rdf:type owl:Class ;
    rdfs:subClassOf context:Category ;
    rdfs:label "Predefined"@en ;
    rdfs:comment "Superclass of all built-in context categories shipped with Mia."@en .

context:UserDefined rdf:type owl:Class ;
    rdfs:subClassOf context:Category ;
    rdfs:label "UserDefined"@en ;
    rdfs:comment "Superclass of context categories defined by the Mia user."@en .

context:sbs rdf:type owl:ObjectProperty ;
    rdfs:domain context:Category ;
    rdfs:range context:Context ;
    rdfs:label "self-by-self"@en ;
    rdfs:comment "Links a category to a context DataBook where both subject and assertedBy are :Self — the Mia user is both the subject of and the asserter of the data."@en .

context:sbo rdf:type owl:ObjectProperty ;
    rdfs:domain context:UserDefined ;
    rdfs:range context:SBO-Context ;
    rdfs:label "self-by-other"@en ;
    rdfs:comment "Links a user-defined category to a context DataBook where subject is :Self and assertedBy is another person, organization, or group."@en .

context:obo rdf:type owl:ObjectProperty ;
    rdfs:domain context:UserDefined ;
    rdfs:range context:OBO-Context ;
    rdfs:label "other-by-other"@en ;
    rdfs:comment "Links a user-defined category to a context DataBook where both subject and assertedBy are another person, organization, or group."@en .

context:obs rdf:type owl:ObjectProperty ;
    rdfs:domain context:UserDefined ;
    rdfs:range [ rdf:type owl:Class ;
                 owl:unionOf ( context:Category context:OBS-Context ) ] ;
    rdfs:label "other-by-self"@en ;
    rdfs:comment "Links a user-defined category to either a c:Category or a c:OBS-Context DataBook (subject is another person/org/group, assertedBy is :Self)."@en .

context:child rdf:type owl:ObjectProperty ;
    rdfs:domain context:Category ;
    rdfs:range context:Category ;
    rdfs:label "child"@en ;
    rdfs:comment "Links a category to a more specific child category."@en .

#################################################################
#    c:Groups Contexts and subclasses
#################################################################


context:Groups rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Groups"@en ;
    rdfs:comment "Interactions with a formal or informal group of people."@en .


#################################################################
#    c:People Contexts and subclasses
#################################################################

context:People rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "People"@en ;
    rdfs:comment "Interactions with all kinds of people."@en .

context:Family rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Family"@en ;
    rdfs:comment "Interactions with a family member."@en .

context:MarriagePartner rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Marriage/Partner"@en ;
    rdfs:comment "Relationships with a spouse or life partner."@en .

context:Friends rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Friends"@en ;
    rdfs:comment "Interactions with friends."@en .

context:Consultants rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Consultants"@en ;
    rdfs:comment "Interactions with consultants who provide services."@en .

#################################################################
#    c:Work Contexts and subclasses
#################################################################

context:Work rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Work"@en ;
    rdfs:comment "Professional roles, employment history, and career relationships."@en .

context:Employee rdf:type owl:Class ;
    rdfs:subClassOf context:Work ;
    rdfs:label "Employee"@en ;
    rdfs:comment "Related to being an employee."@en .

context:Contributor rdf:type owl:Class ;
    rdfs:subClassOf context:Work ;
    rdfs:label "Contributor"@en ;
    rdfs:comment "Related to contributing to initiatives started or led by others."@en .

context:Creator rdf:type owl:Class ;
    rdfs:subClassOf context:Work ;
    rdfs:label "Creator"@en ;
    rdfs:comment "Related to being a creator, inventor, founder, author of something."@en .


#################################################################
#    c:Companies Contexts and subclasses
#################################################################

context:Companies rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Companies"@en ;
    rdfs:comment "Relationship with a specific company or other institution."@en .




#################################################################
#    c:Finances Context (personal finance, no institution)
#################################################################

context:Finances rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Finances"@en ;
    rdfs:comment "Information about personal finances not related to any interactions with banks, financial institutions or government agencies."@en .

context:FinancialServices rdf:type owl:Class ;
    rdfs:subClassOf context:Finances ;
    rdfs:label "FinancialServices"@en ;
    rdfs:comment "Relationship with a bank or other financial services institution."@en .

#################################################################
#    c:Health Context (personal wellness, no provider)
#################################################################

context:Health rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Health"@en ;
    rdfs:comment "Personal health and wellness information not related to any specific healthcare provider."@en .

context:Healthcare rdf:type owl:Class ;
    rdfs:subClassOf context:Health ;
    rdfs:label "Healthcare"@en ;
    rdfs:comment "Relationship with a healthcare provider or health insurance company."@en .

#################################################################
#    c:Event Contexts and subclasses
#################################################################    

context:Events rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Events"@en ;
    rdfs:comment "Participation in or relationship to a specific event."@en .

context:Meetings rdf:type owl:Class ;
    rdfs:subClassOf context:Events ;
    rdfs:label "Meetings"@en ;
    rdfs:comment "A meeting or appointment."@en .

context:Conferences rdf:type owl:Class ;
    rdfs:subClassOf context:Events ;
    rdfs:label "Conferences"@en ;
    rdfs:comment "A conference or professional gathering."@en .

context:Parties rdf:type owl:Class ;
    rdfs:subClassOf context:Events ;
    rdfs:label "Parties"@en ;
    rdfs:comment "A party or social celebration."@en .

#################################################################
#    c:Government Contexts and subclasses
################################################################# 

context:Government rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Government"@en ;
    rdfs:comment "Government-issued credentials, tax records, and civic relationships."@en .

context:Federal rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "Federal"@en ;
    rdfs:comment "Federal government context (e.g. passport, federal tax records)."@en .

context:State rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "State"@en ;
    rdfs:comment "State government context (e.g. driver's license, state tax records)."@en .

context:Municipality rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "Municipality"@en ;
    rdfs:comment "Municipal government context (e.g. local permits, library card)."@en .

#################################################################
#    c:Note Contexts and subclasses
################################################################# 

context:Notes rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Notes"@en ;
    rdfs:comment "Notes about topics not covered by any other context category."@en .

context:Learnings rdf:type owl:Class ;
    rdfs:subClassOf context:Notes ;
    rdfs:label "Learnings"@en ;
    rdfs:comment "Knowledge gained from personal experience"@en .

#################################################################
#    c:Possessions Contexts and subclasses
################################################################# 

context:Possessions rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Possessions"@en ;
    rdfs:comment "Owned assets, property, vehicles, and other possessions."@en .

context:Vehicles rdf:type owl:Class ;
    rdfs:subClassOf context:Possessions ;
    rdfs:label "Vehicles"@en ;
    rdfs:comment "Owning and maintaining a vehicle."@en .

context:Pets rdf:type owl:Class ;
    rdfs:subClassOf context:Possessions ;
    rdfs:label "Pets"@en ;
    rdfs:comment "Taking care of pets."@en .

context:Home rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Home"@en ;
    rdfs:comment "Owning or renting a home or other dwelling."@en .

#################################################################
#    c:Project Contexts and subclasses
################################################################# 

context:Projects rdf:type owl:Class ;
    rdfs:subClassOf context:Predefined ;
    rdfs:label "Projects"@en ;
    rdfs:comment "Involvement in a specific project or initiative."@en .
