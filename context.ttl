@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/context> .

<http://mee.foundation/ontologies/context> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/context/1.0.1> ;
    dc:date "2026-06-01"^^xsd:date ;
    owl:imports <http://mee.foundation/ontologies/identity> ;
    owl:versionInfo "Version 1.0.6 - replaced assertionType/AssertionType with assertedBy pointing to identity:MeeIdentity"@en ;
    rdfs:label "Context Ontology"@en ;
    rdfs:comment """Context Ontology for the Mee Identity Agent.

                    Defines controlled vocabularies for classifying context ontology files:
                    - contextCategory: the kind of relationship a context file represents
                    - assertedBy: the identity asserting the data (an identity:MeeIdentity subclass)
                    - subjectType: whose identity the file describes (Self vs. Other)

                    Peer of persona.ttl and identity.ttl; imported directly by each context file."""@en .


#################################################################
#    Annotation Properties for Context File Classification
#################################################################

context:contextCategory rdf:type owl:AnnotationProperty ;
    rdfs:label "context type"@en ;
    rdfs:comment """Tags a context ontology (file) with the kind of relationship it represents —
                    e.g. context:Company, context:Federal, context:Municipality.
                    Applied to the ontology IRI, not to the Persona individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range context:ContextCategory .

context:assertedBy rdf:type owl:AnnotationProperty ;
    rdfs:label "asserted by"@en ;
    rdfs:comment """Tags a context ontology (file) with the kind of identity making the assertion —
                    a subclass of identity:MeeIdentity (e.g. identity:Self, identity:Corporation).
                    Applied to the ontology IRI, not to the Persona individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range identity:MeeIdentity .

context:subjectType rdf:type owl:AnnotationProperty ;
    rdfs:label "subject"@en ;
    rdfs:comment """Tags a context ontology (file) with whose identity it describes —
                    context:Self (the file is about the identity owner) or
                    context:ThirdParty (the file is about another person or entity).
                    Applied to the ontology IRI, not to the Persona individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range context:SubjectType .



#################################################################
#    Subject Type Hierarchy
#################################################################

context:SubjectType rdf:type owl:Class ;
    rdfs:label "Subject Type"@en ;
    rdfs:comment "Controlled vocabulary for whose identity a context file describes."@en .

context:Self rdf:type owl:Class ;
    rdfs:subClassOf context:SubjectType ;
    rdfs:label "Self"@en ;
    rdfs:comment "The context file describes the identity owner themselves."@en .

context:Other rdf:type owl:Class ;
    rdfs:subClassOf context:SubjectType ;
    rdfs:label "Other"@en ;
    rdfs:comment "The context file describes another person or entity (not the identity owner)."@en .


#################################################################
#    Context Categories
#    Subclasses are used as values for the context:contextCategory
#    annotation property on ontology IRIs (context files)
#################################################################

context:ContextCategory rdf:type owl:Class ;
    rdfs:label "ContextCategory"@en ;
    rdfs:comment """Controlled vocabulary for categories of contexts. 
                    Used as the value of context:contextCategory on ontology IRIs."""@en .

context:Possession rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Possession"@en ;
    rdfs:comment "Owned assets, property, vehicles, and other possessions."@en .

context:Project rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Project"@en ;
    rdfs:comment "Involvement in a specific project or initiative."@en .

context:Event rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Event"@en ;
    rdfs:comment "Participation in or relationship to a specific event."@en .

context:Learning rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Learning"@en ;
    rdfs:comment "Educational experiences, courses, and certifications."@en .

context:Topic rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Topic"@en ;
    rdfs:comment "Interest in or expertise around a specific subject area."@en .

#################################################################
#    Company and subclasses
#################################################################

context:Company rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Company"@en ;
    rdfs:comment "Relationship with a specific company, bank, or other institution."@en .

context:Finance rdf:type owl:Class ;
    rdfs:subClassOf context:Company ;
    rdfs:label "Finance"@en ;
    rdfs:comment "Financial services company"@en .    

context:Health rdf:type owl:Class ;
    rdfs:subClassOf context:Company ;
    rdfs:label "Health"@en ;
    rdfs:comment "Health and wellness company"@en .        

#################################################################
#    Career and subclasses
#################################################################

context:Career rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Career"@en ;
    rdfs:comment "Professional roles, employment history, and career relationships."@en .

context:Employee rdf:type owl:Class ;
    rdfs:subClassOf context:Career ;
    rdfs:label "Employee"@en ;
    rdfs:comment "Related to being an employee."@en .

context:Contributor rdf:type owl:Class ;
    rdfs:subClassOf context:Career ;
    rdfs:label "Contributor"@en ;
    rdfs:comment "Related to contributing to initiatives started or led by others."@en .

context:Creator rdf:type owl:Class ;
    rdfs:subClassOf context:Career ;
    rdfs:label "Creator"@en ;
    rdfs:comment "Related to being a creator, inventor, founder, author of something."@en .


#################################################################
#    Government and subclasses
#################################################################

context:Government rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "Government"@en ;
    rdfs:comment "Government-issued credentials, tax records, and civic relationships."@en .

context:Federal rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "Federal"@en ;
    rdfs:comment "Federal government context (e.g. passport, federal tax records)."@en .

context:State rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "State"@en ;
    rdfs:comment "State government context (e.g. driver's license, state tax records)."@en .

context:Municipality rdf:type owl:Class ;
    rdfs:subClassOf context:Government ;
    rdfs:label "Municipality"@en ;
    rdfs:comment "Municipal government context (e.g. local permits, library card)."@en .

#################################################################
#    People and subclasses
#################################################################

context:People rdf:type owl:Class ;
    rdfs:subClassOf context:ContextCategory ;
    rdfs:label "People"@en ;
    rdfs:comment "Interactions with all kinds of people."@en .

context:Family rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Family"@en ;
    rdfs:comment "Interactions with family members."@en .

context:Friends rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Friends"@en ;
    rdfs:comment "Interactions with friends."@en .

context:Consultants rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Consultants"@en ;
    rdfs:comment "Interactions with consultants who provide services."@en .

context:Colleagues rdf:type owl:Class ;
    rdfs:subClassOf context:People ;
    rdfs:label "Colleagues"@en ;
    rdfs:comment "Interactions with others with whom you work."@en .
