@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix cell: <http://mee.foundation/ontologies/cell#> .
@prefix p: <http://mee.foundation/ontologies/persona#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/context> .

<http://mee.foundation/ontologies/context> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/context/1.8.0> ;
    dc:date "2026-07-11"^^xsd:date ;
    owl:imports <http://mee.foundation/ontologies/cell> ;
    owl:versionInfo "Version 1.8.0 - deleted context:SBScontext/OBScontext/OBOcontext/SBOcontext: context:SCcontext is no longer an abstract intermediate superclass but the concrete class every self-vs-other classified context is typed as directly. context:about-by's value remains one of the same four conventional string labels (\"context:SBScontext\", \"context:OBScontext\", \"context:OBOcontext\", \"context:SBOcontext\"), but these are now plain descriptive strings rather than references to real owl:Class terms — no data migration needed, existing about-by values are unchanged. (Version 1.7.0 - renamed context:XBXcontext to context:SCcontext (Subject-Claimant context), matching cell.ttl 3.4.0's new cell:sc-context property (which replaces cell:sbs/obs/sbo/obo with a single multi-valued link, range context:SCcontext) — the four leaf subtypes (SBScontext/OBScontext/OBOcontext/SBOcontext) are unchanged. (Version 1.6.0 - relaxed context:subject and context:claimant's range from identity:PDNidentifier to a union of p:Person/g:Group/o:Organization, matching how these fields are actually populated in DataBooks (a subject/claimant is the identity itself, not a PDN identifier of it) — see persona-shacl.ttl's new :XBXcontextShape. context.ttl no longer imports pdn-identity, since nothing here references identity: terms anymore. (Version 1.5.0 - removed context:cell: it duplicated, in the reverse direction, the link already carried by cell:sbs/obs/sbo/obo/graph (Cell -> Context) — the same redundancy shape as the now-resolved cat:forCell/cell:catNode case, where the forward-pointing property was deleted in favor of a single direction of record. A context DataBook's containing cell is now found only by reverse lookup (which cell:Cell asserts sbs/obs/sbo/obo/graph to this context), never by a field on the context itself. context.ttl still imports cell.ttl, now solely to reuse cell:abstract on context:Context/context:XBXcontext. (Version 1.4.0 - context:cell's range changed from cell:Cell (the tree-position class, now renamed cat:Category and split out into category.ttl) to the new cell:Cell (formerly cell:Parties) — the content-holding class that actually asserts sbs/obs/sbo/obo/graph))))"@en ;
    rdfs:label "Context Ontology"@en ;
    rdfs:comment """Context Ontology for the Mee Identity Agent"""@en .


#################################################################
#    Annotation Properties for Context DataBook Classification
#################################################################

context:claimant rdf:type owl:AnnotationProperty ;
    rdfs:label "claimed by"@en ;
    rdfs:comment """Annotates a DataBook named graph with the identity making the claim —
                    a named individual of p:Person, g:Group, or o:Organization (e.g. :Self,
                    a p:Person, g:Group, or o:Organization instance). Applied to the named
                    graph IRI, not to the Person individual."""@en ;
    rdfs:domain context:SCcontext ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( p:Person g:Group o:Organization ) ] .

context:subject rdf:type owl:AnnotationProperty ;
    rdfs:label "subject"@en ;
    rdfs:comment """Annotates a DataBook named graph with whose identity it describes —
                    a named individual of p:Person, g:Group, or o:Organization (e.g. :Self,
                    a p:Person, g:Group, or o:Organization instance). Applied to the named
                    graph IRI, not to the Person individual."""@en ;
    rdfs:domain context:SCcontext ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( p:Person g:Group o:Organization ) ] .

context:template rdf:type owl:AnnotationProperty ;
    rdfs:label "template"@en ;
    rdfs:comment """Annotates a DataBook named graph with the persona template type that applies to it.
                    Value is one of the persona:PersonaTemplate subclasses
                    (persona:BirthCertificate, persona:JSContactCard, persona:DriversLicense, persona:Passport).
                    Used to select the appropriate per-template SHACL shapes file for validation.
                    Applied to the named graph IRI."""@en ;
    rdfs:domain context:Context ;
    rdfs:range <http://mee.foundation/ontologies/persona#PersonaTemplate> .

context:about-by rdf:type owl:AnnotationProperty ;
    rdfs:label "about-by"@en ;
    rdfs:comment "Classifies a DataBook named graph by the combination of subject and claimant. Value is one of four conventional string labels: \"context:SBScontext\" (Self-by-Self: subject=Self, claimant=Self), \"context:OBScontext\" (Other-by-Self: subject=Other, claimant=Self), \"context:OBOcontext\" (Other-by-Other: subject=Other, claimant=Other), or \"context:SBOcontext\" (Self-by-Other: subject=Self, claimant=Other). These are plain descriptive strings, not references to owl:Class terms — context:SCcontext has no subclasses."@en ;
    rdfs:domain context:SCcontext .


#################################################################
#    Context (DataBook) and SCcontext
#################################################################

context:Context rdf:type owl:Class ;
    cell:abstract true ;
    rdfs:label "Context"@en ;
    rdfs:comment "A context DataBook — a named graph containing identity data about a person in a specific relationship or situation."@en .

context:SCcontext rdf:type owl:Class ;
    rdfs:subClassOf context:Context ;
    rdfs:label "SCcontext"@en ;
    rdfs:comment "Subject-Claimant context: the concrete class every self-vs-other classified context DataBook is typed as directly — it has no subclasses (the former SBScontext/OBScontext/OBOcontext/SBOcontext were deleted; the four cases they distinguished are now conventional string values of context:about-by instead of separate classes). Carries the about-by, subject, and claimant annotations — a context linked via cell:graph rather than cell:sc-context is a plain context:Context, not a context:SCcontext, and so does not carry these annotations."@en .

