@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix cell: <http://mee.foundation/ontologies/cell#> .
@prefix p: <http://mee.foundation/ontologies/persona#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/context> .

<http://mee.foundation/ontologies/context> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/context/1.11.0> ;
    dc:date "2026-07-18"^^xsd:date ;
    owl:imports <http://mee.foundation/ontologies/cell> ;
    owl:versionInfo "Version 1.11.0 - corrected context:subject/context:claimant/context:template's doc comments, which said they were 'applied to the named graph IRI' (i.e. the #graph-suffixed graph.named_graph IRI): in every real context DataBook, and per what cell:sc-context actually links to, they're applied to the DataBook's own plain id instead. Also clarified context:Context's class comment to the same effect. No change to any rdfs:domain/range or actual triples — documentation only, first noticed while building yaml-to-rdf.py's YAML-to-RDF synthesis."@en ;
    rdfs:label "Context Ontology"@en ;
    rdfs:comment """Context Ontology for the Mee Identity Agent"""@en .


#################################################################
#    Annotation Properties for Context DataBook Classification
#################################################################

context:claimant rdf:type owl:AnnotationProperty ;
    rdfs:label "claimed by"@en ;
    rdfs:comment """Annotates a context DataBook with the identity making the claim —
                    a named individual of p:Person, g:Group, or o:Organization (e.g. :Self,
                    a p:Person, g:Group, or o:Organization instance). Applied to the context
                    DataBook's own IRI (its plain `id`) — the same IRI cell:sc-context links
                    to from the cell side — not to the `#graph`-suffixed `graph.named_graph`
                    IRI, and not to the Person individual."""@en ;
    rdfs:domain context:SCcontext ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( p:Person g:Group o:Organization ) ] .

context:subject rdf:type owl:AnnotationProperty ;
    rdfs:label "subject"@en ;
    rdfs:comment """Annotates a context DataBook with whose identity it describes —
                    a named individual of p:Person, g:Group, or o:Organization (e.g. :Self,
                    a p:Person, g:Group, or o:Organization instance). Applied to the context
                    DataBook's own IRI (its plain `id`) — the same IRI cell:sc-context links
                    to from the cell side — not to the `#graph`-suffixed `graph.named_graph`
                    IRI, and not to the Person individual."""@en ;
    rdfs:domain context:SCcontext ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( p:Person g:Group o:Organization ) ] .

context:template rdf:type owl:AnnotationProperty ;
    rdfs:label "template"@en ;
    rdfs:comment """Annotates a context DataBook with the persona template type that applies to it.
                    Value is one of the persona:PersonaTemplate subclasses (persona:BirthCertificateDocument,
                    persona:JSContactCard, persona:DriversLicenseDocument, persona:PassportDocument,
                    persona:MedicalAppointmentRecord).
                    Used to select the appropriate per-template SHACL shapes file for validation.
                    Applied to the context DataBook's own IRI (its plain `id`), not the
                    `#graph`-suffixed `graph.named_graph` IRI — matching context:subject and
                    context:claimant."""@en ;
    rdfs:domain context:Context ;
    rdfs:range <http://mee.foundation/ontologies/persona#PersonaTemplate> .


#################################################################
#    Context (DataBook) and SCcontext
#################################################################

context:Context rdf:type owl:Class ;
    cell:abstract true ;
    rdfs:label "Context"@en ;
    rdfs:comment "A context DataBook — containing identity data about a person in a specific relationship or situation, extracted into a named graph (graph.named_graph, the DataBook's own `id` plus a `#graph` fragment). Instances of this class and its annotations (context:subject, context:claimant, context:template) are typed and asserted on the DataBook's own `id` IRI, not the `#graph`-suffixed named graph IRI that wraps its extracted content."@en .

context:SCcontext rdf:type owl:Class ;
    rdfs:subClassOf context:Context ;
    rdfs:label "SCcontext"@en ;
    rdfs:comment "Subject-Claimant context: the concrete class every self-vs-other classified context DataBook is typed as directly — it has no subclasses (the former SBScontext/OBScontext/OBOcontext/SBOcontext were deleted; the four self-vs-other cases they distinguished are now determined directly from the combination of subject and claimant, rather than from a separate context:about-by value or distinct rdf:types). Carries the subject and claimant annotations — a context linked via cell:graph rather than cell:sc-context is a plain context:Context, not a context:SCcontext, and so does not carry these annotations."@en .

