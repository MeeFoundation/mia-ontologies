context:Legal\(org\) rdf:type owl:Class ;
    rdfs:subClassOf context:OrgPredefined ;
    rdfs:label "Legal (org)"@en ;
    rdfs:comment "Legal matters, contracts, and agreements involving organizations."@en .

context:KnowledgeBase rdf:type owl:Class ;
    rdfs:subClassOf context:OrgPredefined ;
    rdfs:label "KnowledgeBase"@en ;
    rdfs:comment "Corporate knowledge bases and organizational information not covered by other org categories."@en .

context:Consultants\(org\) rdf:type owl:Class ;
    rdfs:subClassOf context:OrgPredefined ;
