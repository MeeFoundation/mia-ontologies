@prefix cell: <http://mee.foundation/ontologies/cell#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix p: <http://mee.foundation/ontologies/persona#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/cell> .

<http://mee.foundation/ontologies/cell> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/cell/3.6.0> ;
    dc:date "2026-07-13"^^xsd:date ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    owl:versionInfo "Version 3.6.0 - added cell:templateShapes (owl:ObjectProperty, domain cell:Cell, range sh:NodeShape), moved here from category.ttl's cat:templateShapes (added there in category.ttl 1.9.0): its domain/range never actually referenced any cat: term, so it belongs here rather than in category.ttl. This lets cell-templates.ttl drop its owl:imports of category.ttl and import cell.ttl directly instead, ending the mutual import that previously existed between category.ttl and cell-templates.ttl."@en ;
    rdfs:label "Cell Ontology"@en ;
    rdfs:comment """Cell Ontology for the Mee Identity Agent. Defines cell:Cell — the self-contained content facet of a cell (its party composition and its links to context data) — independent of where any cat:Category (see category.ttl) chooses to place it in a navigational tree."""@en .


#################################################################
#    Annotation Properties for Cell DataBook Classification
#################################################################

cell:abstract rdf:type owl:AnnotationProperty ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean ;
    rdfs:label "abstract"@en ;
    rdfs:comment "True if this class is not directly instantiated in DataBooks — it exists only to organize the class hierarchy."@en .

cell:label rdf:type owl:AnnotationProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range xsd:string ;
    rdfs:label "label"@en ;
    rdfs:comment "Default display name for a concrete cell:Cell subtype (e.g. \"Two-Party Cell\"), asserted directly on the class rather than an instance. Distinct from category.ttl's cat:label, which is the user-editable per-instance display name of an associated cat:Category — cell.ttl cannot reference cat:label since category.ttl imports cell.ttl, not the reverse."@en .

cell:templateShapes rdf:type owl:ObjectProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range sh:NodeShape ;
    rdfs:label "templateShapes"@en ;
    rdfs:comment "Links a template cell:Cell individual (one reached via a cat:Category subclass's cat:templateCell, category.ttl) directly to the sh:NodeShape(s) that describe the content a context file filed under that category is expected to conform to — e.g. ctpl:PassportTemplateCell (cell-templates.ttl) carries pshapes:PassportDocumentShape (cell-templates-shacl.ttl). Makes the shape reachable by RDF traversal alone (cat:Category -> cat:templateCell -> cell:templateShapes -> sh:NodeShape), not merely by file co-location or naming convention. A template cell with no known shape (most of them) carries no cell:templateShapes value. Formerly cat:templateShapes (category.ttl); moved here in cell.ttl 3.6.0 since its domain (cell:Cell) and range (sh:NodeShape) never actually referenced any cat: term — this also lets cell-templates.ttl drop its owl:imports of category.ttl entirely, since the only cat: term it ever used was this property."@en .


#################################################################
#    Cell
#
#    A cell:Cell instance is a self-contained content record — its
#    party composition, and any sc-context/graph links to context
#    DataBooks — independent of any tree position in a category tree. 
#    A cell:Cell is pointed at by a cat:Node's cat:cell property; a cell has no
#    way to discover its own node(s) other than by reverse lookup on
#    the category side. The relationship is many-to-one, not 1:1: one
#    or more cell:Cell individuals may share the same cat:Node, each
#    an independent piece of content at that one tree position. 
#    Cells vary by how many total parties (the user plus zero or more others)
#    are involved in the relationship it represents: cell:OneParty
#    (the user alone), or cell:MultiParty (the user plus one or more
#    others, further split into cell:TwoParty and cell:ThreePlusParty).
#################################################################

cell:Cell rdf:type owl:Class ;
    cell:abstract true ;
    rdfs:label "Cell"@en ;
    rdfs:comment "Superclass classifying every cell instance by total party count: cell:OneParty (the user alone) or cell:MultiParty (the user plus one or more others, further split into cell:TwoParty and cell:ThreePlusParty). cell:parties records the same classification via a class-valued object property (its value is the concrete subclass itself, not a string). Formerly named cell:Parties as a class (the tree-position class, before cell.ttl's 3.0.0 split moved that name to category.ttl's cat:Category); the unrelated cell:num-parties property was itself later renamed to cell:parties. A cell:Cell carries no tree position of its own and no link to one — it is a self-contained content record (party composition plus sc-context/graph/note/folder). It is instead pointed at by a cat:Node's cat:cell property (see category.ttl); attaching or moving a cell in any tree only ever touches that node's own cat:cell, never anything on the cell itself, which is what keeps a cell robust under PDN sync."@en .

cell:MultiParty rdf:type owl:Class ;
    cell:abstract true ;
    rdfs:subClassOf cell:Cell ;
    rdfs:label "MultiParty"@en ;
    rdfs:comment "Abstract superclass of the two cell types involving more than one total party: cell:TwoParty (exactly one other party) and cell:ThreePlusParty (two or more other parties, e.g. a group)."@en .

cell:TwoParty rdf:type owl:Class ;
    rdfs:subClassOf cell:MultiParty ;
    rdfs:label "TwoParty"@en ;
    cell:label "Two-Party Cell" ;
    rdfs:comment "A cell representing a 1:1 relationship with a specific person, organization, or other party."@en .

cell:ThreePlusParty rdf:type owl:Class ;
    rdfs:subClassOf cell:MultiParty ;
    rdfs:label "ThreePlusParty"@en ;
    cell:label "Multi-Party Cell" ;
    rdfs:comment "A cell representing a shared relationship with two or more other parties — e.g. a group of people or organizations. Not to be confused with g:Group (a PDN group node)."@en .

cell:OneParty rdf:type owl:Class ;
    rdfs:subClassOf cell:Cell ;
    rdfs:label "OneParty"@en ;
    cell:label "Cell" ;
    rdfs:comment "A cell with no external party — plain content with no connection or group semantics."@en .

cell:graph rdf:type owl:ObjectProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range context:Context ;
    rdfs:label "graph"@en ;
    rdfs:comment "Links a cell to a plain context DataBook that does not fit the self-vs-other classification carried by cell:sc-context — e.g. claims jointly maintained by multiple parties about a third party, rather than data cleanly claimable as self-vs-other. Unlike cell:sc-context, no subject/claimant classification is implied by this property; the target context is typed context:Context directly rather than context:SCcontext."@en .

cell:sc-context rdf:type owl:ObjectProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range context:SCcontext ;
    rdfs:label "sc-context"@en ;
    rdfs:comment "Links a cell to any number of Subject-Claimant classified context DataBooks (context:SCcontext, which has no subclasses — see context.ttl 1.9.0). Replaces the former cell:sbs/cell:obs/cell:sbo/cell:obo (each restricted to one of the four self-vs-other cases and, for the other-party three, to cell:MultiParty): a single multi-valued property now covers every case uniformly, on any cell:Cell regardless of party count. Which of the four cases (self-by-self, other-by-self, other-by-other, self-by-other) a given value represents comes from that context's own subject/claimant combination, not from which property linked it or from a distinct rdf:type. Cardinality is unconstrained — a cell may have zero, one, or many cell:sc-context values."@en .

cell:creator rdf:type owl:ObjectProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( p:Person g:Group o:Organization ) ] ;
    rdfs:label "creator"@en ;
    rdfs:comment "Identifies who created a cell's content — a named individual of p:Person, g:Group, or o:Organization. At most one value. Mirrors the union-range pattern used by context:subject and context:claimant (context.ttl), referencing those classes by name without owl:imports."@en .

cell:parties rdf:type owl:ObjectProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range cell:Cell ;
    rdfs:label "parties"@en ;
    rdfs:comment "Links a cell:Cell individual to the concrete cell:Cell subclass it instantiates: cell:OneParty, cell:TwoParty, or cell:ThreePlusParty. Value is the class itself (e.g. cell:OneParty), not a string — mirroring cat:category's (category.ttl) use of class-value punning as an object property's range. Exactly one value required, matching that individual's own rdf:type. Formerly named cell:num-parties."@en .

#################################################################
#    Cell Notes and Folders
#
#    Every cell is associated with two separate but parallel
#    folder hierarchies that mirror its cat:Node's position in
#    the user's tree and are kept in sync by the Mia application:
#
#    Notes hierarchy — one folder per cell plus one .md file
#    per cell, rooted at a configurable notes root (e.g.
#    ~/MiaNotes/). Folder names and nesting match the category tree
#    exactly. The note for a cell is stored as X.md inside the
#    X folder (e.g. Family/Family.md) — the same name as the folder
#    itself. This matches the Obsidian Folder Notes plugin
#    convention, which treats a file named exactly after its
#    containing folder as the note for that folder.
#
#    Traditional PKM tools have no built-in way to associate a note
#    with a folder itself. Mia's same-name convention solves this:
#    the cell note is co-located with its folder and directly
#    compatible with PKM folder-note tools such as Obsidian (Folder
#    Notes plugin), Logseq, or Foam.
#
#    Files hierarchy — one folder per cell, rooted at a
#    configurable files root (e.g. ~/MiaFiles/). Folder names and
#    nesting match the category tree exactly. Each folder may
#    contain arbitrary files and additional subfolders that are not
#    part of the category tree itself.
#
#    When a cat:Node is created, renamed, or deleted, Mia updates
#    both hierarchies automatically for every cell it references via
#    cat:cell. The two roots are stored separately so the notes
#    hierarchy can be opened as a standalone PKM vault without
#    exposing the files hierarchy.
#
#    Redundancy and robustness: in the normal case cell:note and
#    cell:folder are technically redundant — both paths can be
#    derived from the associated cat:Node's tree position plus the
#    two configured roots. They are retained for three reasons:
#
#    1. Divergence detection: if a stored path no longer matches
#       the derived path, Mia knows the user has manually renamed
#       or rearranged folders outside of Mia and can alert them or
#       attempt reconciliation rather than failing silently.
#
#    2. Graceful degradation: Mia can continue to locate a
#       cell's folder or note via the stored path even when
#       the folder hierarchy has drifted out of sync with the
#       category tree.
#
#    3. Intentional overrides: a user may deliberately want a
#       cell's folder to live somewhere other than the derived
#       location (e.g. ~/Photos/Family/ rather than the default
#       ~/MiaFiles/People/Family/). The explicit link records that
#       intentional deviation without disrupting the category tree.
#################################################################

cell:note rdf:type owl:AnnotationProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range xsd:anyURI ;
    rdfs:label "note"@en ;
    rdfs:comment "Relative path within the notes hierarchy root to the cell note file, stored as CellName.md inside the cell folder (e.g. family/Family.md) — matching the Obsidian Folder Notes plugin convention. Normally derived automatically by Mia from the associated cat:Category's tree position; retained explicitly for divergence detection, graceful degradation, and intentional overrides."@en .

cell:folder rdf:type owl:AnnotationProperty ;
    rdfs:domain cell:Cell ;
    rdfs:range xsd:anyURI ;
    rdfs:label "folder"@en ;
    rdfs:comment "Relative path within the files hierarchy root to the folder for this cell. Normally derived automatically by Mia from the associated cat:Category's tree position; retained explicitly for divergence detection, graceful degradation, and intentional overrides."@en .
