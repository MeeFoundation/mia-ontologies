@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/persona-templates> .

<http://mee.foundation/ontologies/persona-templates> rdf:type owl:Ontology ;
    dc:date "2026-06-15"^^xsd:date ;
    owl:versionInfo "Version 1.0.5 - drop BusinessCard; JSContactCard is now the business-card template"@en ;
    rdfs:label "Persona Templates Ontology"@en ;
    rdfs:comment """Reusable p:Persona subtypes that are too specific for persona.ttl
                    but shared across multiple context files.

                    Class hierarchy:
                    p:Persona → p:PersonaTemplate → p:BirthCertificate
                                                  → p:JSContactCard"""@en .


#################################################################
#    PersonaTemplate — abstract superclass for all template subtypes
#################################################################

persona:PersonaTemplate rdf:type owl:Class ;
    rdfs:subClassOf persona:Persona ;
    rdfs:label "Persona Template"@en ;
    rdfs:comment """Abstract superclass for Persona subtypes defined in this file.
                    Subclass of p:Persona; all concrete template types subclass this."""@en .


#################################################################
#    BirthCertificate Persona
#################################################################

persona:BirthCertificate rdf:type owl:Class ;
    rdfs:subClassOf persona:PersonaTemplate ;
    rdfs:label "Birth Certificate Persona"@en ;
    rdfs:comment """A Persona whose purpose is to carry a person's legal birth certificate
                    name record. Subclass of PersonaTemplate so that SHACL can target it
                    directly with sh:targetClass to enforce name constraints."""@en .


#################################################################
#    JSContactCard Persona
#################################################################

persona:JSContactCard rdf:type owl:Class ;
    rdfs:subClassOf persona:PersonaTemplate ;
    rdfs:label "JSContact Card Persona"@en ;
    rdfs:comment """A Persona whose purpose is to carry professional contact details in the
                    JSContact (RFC 9553) format. OrganizationName and at least one contact
                    channel (email or phone) are required. All other fields — name components,
                    OrganizationUnit, JobTitle, addresses, online services, anniversaries,
                    personal info, photo — are optional. SHACL shape enforces these constraints
                    plus maximum cardinality on single-valued name and organisation components."""@en .
