@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/persona-templates> .

<http://mee.foundation/ontologies/persona-templates> rdf:type owl:Ontology ;
    dc:date "2026-07-13"^^xsd:date ;
    owl:versionInfo "Version 2.2.0 - renamed the 4 document/record classes for clarity, adding a suffix matching their existing SHACL shape names and disambiguating from the unrelated cat:BirthCertificate/cat:DriversLicense/cat:Passport category-classification classes (category.ttl) and p:PhysicalDriversLicense (the physical card object, persona.ttl): p:BirthCertificate -> p:BirthCertificateDocument, p:DriversLicense -> p:DriversLicenseDocument, p:Passport -> p:PassportDocument (all matching their :*DocumentShape names), and p:MedicalAppointment -> p:MedicalAppointmentRecord (matching :MedicalAppointmentRecordShape — 'Record' rather than 'Document' since it is explicitly not a p:IdentityDocument). context:template values, SHACL sh:targetClass values, and the affected example context files' rdf:type assertions were all updated to match; the local name each class carries as its context:template YAML value is unchanged in spirit, only longer."@en ;
    rdfs:label "Persona Templates Ontology"@en ;
    rdfs:comment """Template type classification used as values for the context:template annotation property.
                    Each concrete template type (BirthCertificateDocument, JSContactCard, DriversLicenseDocument,
                    PassportDocument, MedicalAppointmentRecord) identifies which per-template SHACL shapes to
                    apply when validating a context file. Four of the five (all but JSContactCard) have their
                    shapes in cell-templates-shacl.ttl, linked from a class-level cell:Cell template
                    (cell-templates.ttl) via cat:templateShapes (category.ttl).

                    p:IdentityDocument models government-issued identity documents as artifact instances.
                    p:BirthCertificateDocument, p:DriversLicenseDocument, and p:PassportDocument are subclasses
                    of both p:PersonaTemplate (template label use) and p:IdentityDocument (artifact instance use).
                    p:JSContactCard is a template label only — not a government-issued identity document.
                    p:MedicalAppointmentRecord is likewise a template label AND the class of the shareable
                    claims record individual (following the same pattern as p:PassportDocument), but is not an
                    IdentityDocument — hence "Record" rather than "Document" in its name.

                    Class hierarchy:
                    p:PersonaTemplate → p:BirthCertificateDocument (also p:IdentityDocument)
                                      → p:DriversLicenseDocument  (also p:IdentityDocument)
                                      → p:PassportDocument        (also p:IdentityDocument)
                                      → p:JSContactCard
                                      → p:MedicalAppointmentRecord
                    p:IdentityDocument → p:BirthCertificateDocument
                                       → p:DriversLicenseDocument
                                       → p:PassportDocument"""@en .


#################################################################
#    PersonaTemplate — abstract superclass for all template subtypes
#################################################################

persona:PersonaTemplate rdf:type owl:Class ;
    rdfs:label "Persona Template"@en ;
    rdfs:comment """Abstract superclass for template type labels used as values for context:template.
                    Concrete subtypes (BirthCertificateDocument, JSContactCard, DriversLicenseDocument)
                    identify which SHACL shapes file applies to a given context file."""@en .


#################################################################
#    IdentityDocument — government-issued document artifact class
#    and hasIdentityDocument property
#################################################################

persona:IdentityDocument rdf:type owl:Class ;
    rdfs:label "Identity Document"@en ;
    rdfs:comment """A government-issued document that formally identifies a person,
                    such as a birth certificate, driver's license, or passport.
                    Subclasses (p:BirthCertificateDocument, p:DriversLicenseDocument, p:PassportDocument)
                    are also p:PersonaTemplate subclasses used as context:template annotation values.
                    Instances are linked from persona:Person via persona:hasIdentityDocument."""@en .

persona:hasIdentityDocument rdf:type owl:ObjectProperty ;
    rdfs:domain persona:Person ;
    rdfs:range persona:IdentityDocument ;
    rdfs:label "has identity document"@en ;
    rdfs:comment "Links a persona:Person to a government-issued identity document they hold."@en .


#################################################################
#    BirthCertificateDocument Template and related properties
#################################################################

persona:BirthCertificateDocument rdf:type owl:Class ;
    rdfs:subClassOf persona:PersonaTemplate ;
    rdfs:subClassOf persona:IdentityDocument ;
    rdfs:label "Birth Certificate"@en ;
    rdfs:comment """Template type label for a context whose purpose is to carry a person's legal
                    birth certificate name record. Used as the value of context:template on the
                    context file's ontology IRI. Selects the SHACL shape :BirthCertificateDocumentShape
                    in cell-templates-shacl.ttl, linked from cat:BirthCertificate's template cell
                    (cell-templates.ttl) via cat:templateShapes — IRI
                    http://mee.foundation/ontologies/persona/shapes/birthcertificate — for
                    validation. Formerly named persona:BirthCertificate; renamed to disambiguate from
                    the unrelated cat:BirthCertificate category-classification class (category.ttl)."""@en .


#################################################################
#    DriversLicense Template and related properties
#################################################################

persona:DriversLicenseNumber rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Driver's License Number"@en ;
    rdfs:comment """A Designative Name identifying a person by their state-issued
                    driver's licence number (e.g. a US DMV licence number string).
                    Used on a driver's license Person via designated by (ont00001879).
                    Distinct from p:PhysicalDriversLicense (in persona.ttl), which models
                    the physical plastic card carried in a wallet."""@en .

persona:IssuingJurisdiction rdf:type owl:Class ;
    rdfs:subClassOf cco:ent00000013 ;  # StateName (subclass of Designative Name)
    rdfs:label "Issuing Jurisdiction"@en ;
    rdfs:comment """The US state (or territory) that issued a government document such as a
                    driver's licence. Subclasses cco:ent00000013 (StateName) so that the
                    existing USStateNameShape in persona-shacl.ttl automatically enforces
                    the USPS 2-letter abbreviation controlled vocabulary (e.g. 'CA', 'TX').
                    Used on a driver's license Person via designated by (ont00001879)."""@en .

persona:DriversLicenseDocument rdf:type owl:Class ;
    rdfs:subClassOf persona:PersonaTemplate ;
    rdfs:subClassOf persona:IdentityDocument ;
    rdfs:label "Driver's License"@en ;
    rdfs:comment """Template type label for a context whose purpose is to carry the identity
                    claims on a state-issued driver's license: legal name, date of birth,
                    driver's license number, and expiration date. Residential address is optional.
                    Used as the value of context:template on the context file's ontology IRI.
                    Selects the SHACL shape :DriversLicenseDocumentShape in cell-templates-shacl.ttl,
                    linked from cat:DriversLicense's template cell (cell-templates.ttl) via
                    cat:templateShapes — IRI
                    http://mee.foundation/ontologies/persona/shapes/driverslicense — for validation.
                    Note: p:PhysicalDriversLicense (in persona.ttl) models the physical card
                    object carried in a wallet; this class models the identity data the
                    license claims. Formerly named persona:DriversLicense; renamed to disambiguate
                    from the unrelated cat:DriversLicense category-classification class
                    (category.ttl) and from p:PhysicalDriversLicense."""@en .


#################################################################
#    Passport Template and related designator classes
#################################################################

persona:PassportNumber rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Passport Number"@en ;
    rdfs:comment """A Designative Name identifying a person by their government-issued passport
                    number. Used on a passport Person via designated by (ont00001879).
                    US passport numbers are 9 alphanumeric characters."""@en .

persona:IssuingCountry rdf:type owl:Class ;
    rdfs:subClassOf cco:ent00000014 ;  # CountryName
    rdfs:label "Issuing Country"@en ;
    rdfs:comment """The country that issued a government document such as a passport.
                    Subclasses cco:ent00000014 (CountryName). Used on a passport Person
                    via designated by (ont00001879). Distinct from p:IssuingJurisdiction
                    which covers US state-issued documents (e.g. driver's licences)."""@en .

persona:PlaceOfBirth rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Place of Birth"@en ;
    rdfs:comment """A Designative Name recording the place where a person was born, as it
                    appears on a government document. Typically a city, state, or country
                    string (e.g. 'Austin, Texas, USA'). Used on a passport or birth certificate
                    Person via designated by (ont00001879)."""@en .

persona:GenderMarker rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Gender Marker"@en ;
    rdfs:comment """A Designative Name recording the gender marker as it appears on a
                    government-issued identity document. Controlled vocabulary: 'M', 'F', 'X'.
                    Used on a passport Person via designated by (ont00001879)."""@en .

persona:IssueDate rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Issue Date"@en ;
    rdfs:comment """A Designative Name recording the date a government document was issued.
                    Value is an ISO 8601 date string ('YYYY-MM-DD'). Used on a Passport or
                    other government-document Person via designated by (ont00001879).
                    Distinct from cco:ent00000046 (Birthdate) and cco:ent00000054
                    (ExpirationDateIdentifier)."""@en .

persona:PassportDocument rdf:type owl:Class ;
    rdfs:subClassOf persona:PersonaTemplate ;
    rdfs:subClassOf persona:IdentityDocument ;
    rdfs:label "Passport"@en ;
    rdfs:comment """Template type label for a context whose purpose is to carry the identity
                    claims on a government-issued passport: legal name, date of birth, passport
                    number, issue date, expiration date, issuing country, place of birth, and
                    gender marker. Photo is optional. Used as the value of context:template on
                    the context file's ontology IRI. Selects the SHACL shape :PassportDocumentShape
                    in cell-templates-shacl.ttl, linked from cat:Passport's template cell
                    (cell-templates.ttl) via cat:templateShapes — IRI
                    http://mee.foundation/ontologies/persona/shapes/passport — for
                    validation. Formerly named persona:Passport; renamed to disambiguate from
                    the unrelated cat:Passport category-classification class (category.ttl)."""@en .


#################################################################
#    JSContactCard Template and related properties
#################################################################

persona:JSContactCard rdf:type owl:Class ;
    rdfs:subClassOf persona:PersonaTemplate ;
    rdfs:label "JSContact Card"@en ;
    rdfs:comment """Template type label for a context whose purpose is to carry professional
                    contact details in the JSContact (RFC 9553) format. OrganizationName and
                    at least one contact channel (email or phone) are required. Used as the
                    value of context:template on the context file's ontology IRI.
                    Selects shacl/jscontactcard-shacl.ttl for validation."""@en .


#  1. Contact Channel Annotation Properties
#     Used on designated-by blank nodes to record JSContact context
#     labels (work/home/other) and phone feature flags.

persona:contactContext rdf:type owl:AnnotationProperty ;
    rdfs:label "contact context"@en ;
    rdfs:comment """JSContact 'contexts' key on an email, phone, or address entry.
                    Controlled vocabulary: 'work', 'home', 'other', 'billing' (address),
                    'delivery' (address)."""@en ;
    rdfs:range xsd:string .

persona:phoneFeature rdf:type owl:AnnotationProperty ;
    rdfs:label "phone feature"@en ;
    rdfs:comment """JSContact phone 'features' flag. Repeat the property for multiple features.
                    Controlled vocabulary: 'voice', 'fax', 'text', 'video', 'pager',
                    'textphone'."""@en ;
    rdfs:range xsd:string .

persona:serviceLabel rdf:type owl:AnnotationProperty ;
    rdfs:label "service label"@en ;
    rdfs:comment """JSContact 'service' field on an onlineServices entry. Identifies which
                    platform the OnlineServiceAccount or WebURL belongs to.
                    Examples: 'twitter', 'linkedin', 'github', 'mastodon'."""@en ;
    rdfs:range xsd:string .


#  2. Name Component Designator Classes
#     All are subclasses of cco:ont00000003 (Designative Name),
#     consistent with GivenName, FamilyName, OrganizationName, etc.

persona:Credential rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Credential"@en ;
    rdfs:comment """A post-nominal professional or academic credential that follows a
                    person's name. Examples: 'MD', 'PhD', 'Esq.', 'CPA', 'MBA'.
                    Distinct from cco:ent00000057 (Title/HonorificPrefix) which precedes
                    the name, and from cco:ent00000005 (Suffix) which covers generational
                    suffixes (Jr., Sr., III).
                    JSContact: name component kind 'credential'."""@en .


#  3. Online Service Designator Class

persona:WebURL rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Web URL"@en ;
    rdfs:comment """A URL that designates a person's web presence — personal website, blog,
                    portfolio, or profile page. Distinct from cco:ent00000033
                    (OnlineServiceAccount) which represents a login-based account.
                    Attach persona:serviceLabel to identify the platform where relevant.
                    JSContact: onlineServices entry with a URI value."""@en .


#  4. Organisation Designator Classes

persona:OrganizationUnit rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Organization Unit"@en ;
    rdfs:comment """A Designative Name identifying a department, division, or other
                    sub-unit within an organization. Typically paired with an
                    OrganizationName (cco:ent00000047) on the same Person.
                    Examples: 'Engineering', 'Sales', 'R&D'.
                    JSContact: organizations[*].units array entry."""@en .

persona:JobTitle rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000003 ;  # Designative Name
    rdfs:label "Job Title"@en ;
    rdfs:comment """A Designative Name for a person's position or role within an
                    organisation. Examples: 'Software Engineer', 'VP of Sales',
                    'Chief Medical Officer'.
                    Distinct from cco:ent00000057 (Title/HonorificPrefix) which is an
                    honorific preceding the name (Dr., Prof., Mr.).
                    JSContact: titles[*].name."""@en .


#  5. Anniversary Class and Properties
#     A named individual of type p:Anniversary is attached to a
#     Person via persona:hasAnniversary.

persona:Anniversary rdf:type owl:Class ;
    rdfs:label "Anniversary"@en ;
    rdfs:comment """A personally significant recurring date, such as a wedding anniversary
                    or other custom commemoration. Birthdays use cco:ent00000046 (Birthdate)
                    directly on the Person via designated-by; Anniversary covers all other
                    recurring dates.
                    JSContact: anniversaries map (excluding 'birth' and 'death' kinds)."""@en .

persona:hasAnniversary rdf:type owl:ObjectProperty ;
    rdfs:label "has anniversary"@en ;
    rdfs:comment "Links a p:Person to one of its Anniversary individuals."@en ;
    rdfs:range persona:Anniversary .

persona:anniversaryKind rdf:type owl:DatatypeProperty ;
    rdfs:label "anniversary kind"@en ;
    rdfs:comment """The type of anniversary. Controlled vocabulary: 'wedding', 'custom'.
                    JSContact: anniversaries[*].kind."""@en ;
    rdfs:domain persona:Anniversary ;
    rdfs:range xsd:string .

persona:anniversaryDate rdf:type owl:DatatypeProperty ;
    rdfs:label "anniversary date"@en ;
    rdfs:comment """The calendar date of the anniversary. Use xsd:date ('YYYY-MM-DD') for
                    fully known dates; xsd:gMonthDay ('--MM-DD') for day/month only.
                    JSContact: anniversaries[*].date."""@en ;
    rdfs:domain persona:Anniversary .

persona:anniversaryLabel rdf:type owl:DatatypeProperty ;
    rdfs:label "anniversary label"@en ;
    rdfs:comment """Human-readable label for a 'custom' anniversary.
                    JSContact: anniversaries[*].label."""@en ;
    rdfs:domain persona:Anniversary ;
    rdfs:range xsd:string .


#  6. PersonalInfo Class and Properties
#     A named individual of type p:PersonalInfo is attached to a
#     Person via persona:hasPersonalInfo.

persona:PersonalInfo rdf:type owl:Class ;
    rdfs:label "Personal Info"@en ;
    rdfs:comment """A record of a person's hobby, personal interest, or area of expertise.
                    JSContact: personalInfo map entries."""@en .

persona:hasPersonalInfo rdf:type owl:ObjectProperty ;
    rdfs:label "has personal info"@en ;
    rdfs:comment "Links a p:Person to one of its PersonalInfo individuals."@en ;
    rdfs:range persona:PersonalInfo .

persona:personalInfoKind rdf:type owl:DatatypeProperty ;
    rdfs:label "personal info kind"@en ;
    rdfs:comment """The category of personal information.
                    Controlled vocabulary: 'expertise', 'hobby', 'interest'.
                    JSContact: personalInfo[*].kind."""@en ;
    rdfs:domain persona:PersonalInfo ;
    rdfs:range xsd:string .

persona:personalInfoValue rdf:type owl:DatatypeProperty ;
    rdfs:label "personal info value"@en ;
    rdfs:comment """The subject matter — e.g. 'rock climbing', 'jazz piano', 'Rust'.
                    JSContact: personalInfo[*].value."""@en ;
    rdfs:domain persona:PersonalInfo ;
    rdfs:range xsd:string .

persona:personalInfoLevel rdf:type owl:DatatypeProperty ;
    rdfs:label "personal info level"@en ;
    rdfs:comment """Self-assessed proficiency level for expertise entries.
                    Controlled vocabulary: 'high', 'medium', 'low'.
                    JSContact: personalInfo[*].level."""@en ;
    rdfs:domain persona:PersonalInfo ;
    rdfs:range xsd:string .


#  7. Photo Property

persona:hasPhoto rdf:type owl:DatatypeProperty ;
    rdfs:label "has photo"@en ;
    rdfs:comment """A URI pointing to a photo or avatar image for this Person.
                    Repeat the property for multiple photos (e.g. work headshot vs
                    informal photo). Use persona:contactContext as an annotation on
                    the reified statement if context labeling is needed.
                    JSContact: photos[*].uri."""@en ;
    rdfs:range xsd:anyURI .


#################################################################
#    MedicalAppointmentRecord Template and related properties
#################################################################

persona:MedicalAppointmentRecord rdf:type owl:Class ;
    rdfs:subClassOf persona:PersonaTemplate ;
    rdfs:label "Medical Appointment"@en ;
    rdfs:comment """Template type label for a context whose purpose is to carry the claims
                    needed to arrange a medical appointment on behalf of someone else (e.g. a
                    family member), shared between the two parties coordinating that care.
                    Also the class of the shareable claims record individual itself, following
                    the same document-individual pattern as p:PassportDocument: the claims below
                    are properties of the MedicalAppointmentRecord, not of the patient's Person
                    individual directly. Any referenced third party (e.g. the patient, their
                    primary care physician) must have their relevant claims copied into this
                    context, since each context's named graph must be self-contained for p2p
                    sync between the coordinating parties' Mia instances. Used as the value
                    of context:template on the context file's
                    ontology IRI. Selects the SHACL shape :MedicalAppointmentRecordShape in
                    cell-templates-shacl.ttl, linked from cat:MedicalAppointmentInfo's template
                    cell (cell-templates.ttl) via cat:templateShapes — IRI
                    http://mee.foundation/ontologies/persona/shapes/medical-appointment — for
                    validation. Formerly named persona:MedicalAppointment; renamed "Record" rather
                    than "Document" since this class is explicitly not a p:IdentityDocument,
                    matching its :MedicalAppointmentRecordShape's existing name."""@en .

persona:forPatient rdf:type owl:ObjectProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:range persona:Person ;
    rdfs:label "for patient"@en ;
    rdfs:comment """Links a MedicalAppointmentRecord to the Person the appointment is for.
                    The linked Person individual must carry copied identity claims (e.g. name),
                    not merely a bare reference — see persona:MedicalAppointmentRecord."""@en .

persona:hasPrimaryCarePhysician rdf:type owl:ObjectProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:range persona:Person ;
    rdfs:label "has primary care physician"@en ;
    rdfs:comment """Links a MedicalAppointmentRecord to the patient's primary care physician.
                    The linked Person individual must carry copied identity claims, not merely
                    a bare reference — see persona:MedicalAppointmentRecord."""@en .

persona:currentMedication rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:label "current medication"@en ;
    rdfs:comment """A medication the patient is currently taking, as a single free-text string
                    (e.g. 'Lisinopril 10mg daily'). Repeat the property for multiple
                    medications. Kept as a flat string rather than a structured sub-object for
                    now; may be upgraded to a dedicated Medication class with dosage/frequency
                    fields later if needed."""@en ;
    rdfs:range xsd:string .

persona:allergy rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:label "allergy"@en ;
    rdfs:comment """An allergy the patient has, as a single free-text string (e.g.
                    'Penicillin'). Repeat the property for multiple allergies."""@en ;
    rdfs:range xsd:string .

persona:medicalHistoryNote rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:label "medical history note"@en ;
    rdfs:comment "A free-text summary of relevant medical history or ongoing conditions."@en ;
    rdfs:range xsd:string .

persona:insuranceProvider rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:label "insurance provider"@en ;
    rdfs:comment "The name of the patient's health insurance provider (e.g. 'Medicare')."@en ;
    rdfs:range xsd:string .

persona:insurancePolicyNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:label "insurance policy number"@en ;
    rdfs:comment "The patient's health insurance policy number."@en ;
    rdfs:range xsd:string .

persona:insuranceGroupNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:label "insurance group number"@en ;
    rdfs:comment "The patient's health insurance group number, if applicable."@en ;
    rdfs:range xsd:string .

persona:preferredPharmacy rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:MedicalAppointmentRecord ;
    rdfs:label "preferred pharmacy"@en ;
    rdfs:comment "The patient's preferred pharmacy, as a free-text name and/or address."@en ;
    rdfs:range xsd:string .
