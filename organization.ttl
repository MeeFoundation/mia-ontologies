@prefix o: <http://mee.foundation/ontologies/organization#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/organization> .

<http://mee.foundation/ontologies/organization> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/organization/1.1.0> ;
    owl:imports <https://purl.org/cco/agent> ;
    dc:date "2026-07-12"^^xsd:date ;
    owl:versionInfo "Version 1.1.0 - removed the owl:Restriction requiring identity:hasPDNidentifier: that property was removed from pdn-identity.ttl 1.3.0 (never populated in the example data). organization.ttl no longer imports pdn-identity.ttl, since nothing here references identity: terms anymore."@en ;
    rdfs:label "Organization Ontology"@en ;
    rdfs:comment """Organization Ontology for the Mee Identity Agent.
                    Describes organizations that participate in the Personal Data Network.
                    Peer of persona.ttl, context.ttl, pdn-identity.ttl, and group.ttl."""@en .


#################################################################
#    Organization
#################################################################

o:Organization rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00001180 ;  # CCO Organization (Group of Agents)
    rdfs:label "Organization"@en ;
    rdfs:comment """An organization (company, government agency, non-profit, etc.)
                    that participates in the Personal Data Network."""@en .
