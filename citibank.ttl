@prefix : <http://www.example.org/mia#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mia> .

<http://www.example.org/mia/citibank> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    dc:date "2026-05-25"^^xsd:date ;
    owl:versionInfo "Version 1.0.1 - add persona:Company context type"@en ;
    rdfs:label "Alice Walker - Citibank Persona"@en ;
    rdfs:comment """Alice Walker's Citibank whoness — the context-specific Persona
                    representing Alice in her Citibank financial relationship.
                    Correlated from :Alice_Walker-Self in self.ttl."""@en .


#################################################################
#    Alice Walker - Citibank Persona
#################################################################

:Alice_Walker-Citibank rdf:type owl:NamedIndividual ,
                                persona:Persona ,
                                persona:Company ;
    rdfs:label "Alice Walker (Citibank)"@en ;
    rdfs:comment "Alice Walker's persona in the context of her Citibank relationship."@en ;

    persona:holdsPaymentCard :Alice_Debit_Card .


#################################################################
#    Payment Card issued to her by Citibank
#################################################################

:Alice_Debit_Card rdf:type owl:NamedIndividual ,
                           cco:ent00000051 ;  # Debit Card
    rdfs:label "Alice Walker's VISA Debit Card"@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → Card Number
        rdf:type cco:ent00000052 ;
        <https://purl.org/cco/ont00001765> "4111-1111-1111-1111"
    ] ;

    <https://purl.org/cco/ont00001879> [  # designated by → CVV
        rdf:type cco:ent00000053 ;
        <https://purl.org/cco/ont00001765> "123"
    ] ;

    <https://purl.org/cco/ont00001879> [  # designated by → Expiration Date
        rdf:type cco:ent00000054 ;
        <https://purl.org/cco/ont00001765> "12/28"
    ] .
