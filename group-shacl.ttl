@prefix : <http://mee.foundation/ontologies/group/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix identity: <http://mee.foundation/ontologies/pdn-identity#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .

<http://mee.foundation/ontologies/group/shapes> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/group> ;
    owl:versionInfo "Version 1.0.2 - update member constraint: persona:Persona → persona:Person; drop hasIdentity minCount (PDN classification moved to graph headers)"@en ;
    rdfs:label "Group Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for the Group Ontology."@en .


#################################################################
#  Group
#################################################################

:GroupShape
    a sh:NodeShape ;
    sh:targetClass g:Group ;
    sh:message "Group validation: must have exactly one identity:hasPDNidentifier of type identity:Group."@en ;

    # Members: BFO has member part → persona:Person or o:Organization
    sh:property [
        sh:path obo:BFO_0000115 ;
        sh:or (
            [ sh:class persona:Person ]
            [ sh:class o:Organization ]
        ) ;
        sh:message "All group member parts (BFO_0000115) must be persona:Person or o:Organization instances."@en
    ] .
