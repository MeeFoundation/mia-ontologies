@prefix : <http://mee.foundation/ontologies/organization/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .

<http://mee.foundation/ontologies/organization/shapes> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/organization> ;
    owl:versionInfo "Version 1.0.0 - initial"@en ;
    rdfs:label "Organization Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for the Organization Ontology."@en .


#################################################################
#  Organization
#################################################################

:OrganizationShape
    a sh:NodeShape ;
    sh:targetClass o:Organization ;
    sh:message "Organization validation: must have exactly one identity:hasIdentity of type identity:Organization."@en ;

    sh:property [
        sh:path identity:hasIdentity ;
        sh:qualifiedValueShape [ sh:class identity:Organization ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "An o:Organization must have exactly one identity:hasIdentity value of type identity:Organization."@en
    ] .
