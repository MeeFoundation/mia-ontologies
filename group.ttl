@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/group> .

<http://mee.foundation/ontologies/group> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/group/1.1.0> ;
    owl:imports <https://purl.org/cco/agent> ;
    dc:date "2026-07-12"^^xsd:date ;
    owl:versionInfo "Version 1.1.0 - removed the owl:Restriction requiring identity:hasPDNidentifier: that property was removed from pdn-identity.ttl 1.3.0 (never populated in the example data). group.ttl no longer imports pdn-identity.ttl, since nothing here references identity: terms anymore."@en ;
    rdfs:label "Group Ontology"@en ;
    rdfs:comment """Group Ontology for the Mee Identity Agent.
                    Describes groups or communities that participate in the Personal Data Network.
                    Peer of persona.ttl, context.ttl, pdn-identity.ttl, and organization.ttl."""@en .


#################################################################
#    Group
#################################################################

g:Group rdf:type owl:Class ;
    rdfs:subClassOf cco:ont00000300 ;  # CCO Group of Agents
    rdfs:label "Group"@en ;
    rdfs:comment """A group or community of people that participates in the Personal Data Network."""@en .
