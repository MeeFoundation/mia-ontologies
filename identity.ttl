@prefix identity: <http://mee.foundation/ontologies/identity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/identity> .

<http://mee.foundation/ontologies/identity> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/identity/1.0.0> ;
    dc:date "2026-06-05"^^xsd:date ;
    owl:versionInfo "Version 1.0.6 - fix stale 'Persona' → 'Person' in hasIdentity comment"@en ;
    rdfs:label "Identity Ontology"@en ;
    rdfs:comment """Identity Ontology for the Mee Identity Agent.
                    Describes the kinds of identities used in the Personal Data Network.
                    Peer of persona.ttl and context.ttl."""@en .


#################################################################
#    Identity Hierarchy
#################################################################

identity:PDNidentity rdf:type owl:Class ;
    rdfs:subClassOf <https://purl.org/cco/ont00000958> ;  # Information Content Entity
    rdfs:label "Mee Identity"@en ;
    rdfs:comment "Root class for all kinds of identities that Mia can communicate with over the internet using Personal Data Network protocols."@en .

identity:Individual rdf:type owl:Class ;
    rdfs:subClassOf identity:PDNidentity ;
    rdfs:label "Individual"@en ;
    rdfs:comment "An identifier of a human Mia user."@en .

identity:Self rdf:type owl:NamedIndividual ,
                       identity:Individual ;
    rdfs:label "Self"@en ;
    rdfs:comment "The well-known singleton individual representing the current Mia user's PDN identity. Used as the value of context:assertedBy and context:subject when the context concerns the local Mia user."@en .

identity:Group rdf:type owl:Class ;
    rdfs:subClassOf identity:PDNidentity ;
    rdfs:label "Group"@en ;
    rdfs:comment "An identifier of a group of Mia users."@en .

identity:Organization rdf:type owl:Class ;
    rdfs:subClassOf identity:PDNidentity ;
    rdfs:label "Organization"@en ;
    rdfs:comment "An identifier of an organization (company, government agency, non-profit, etc.)."@en .


#################################################################
#    hasIdentity property - links a Person to a PDN identity
#################################################################
identity:hasIdentity rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf <https://purl.org/cco/ont00001879> ;  # designated by
    rdfs:range identity:PDNidentity ;
    rdfs:label "has identity"@en ;
    rdfs:comment "Links a Person to a PDN identity — the identifier used to communicate with this Person over the Personal Data Network. Sub-property of CCO designated by (ont00001879)."@en .
