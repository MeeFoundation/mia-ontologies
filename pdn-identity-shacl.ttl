@prefix : <http://mee.foundation/ontologies/pdn-identity/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix identity: <http://mee.foundation/ontologies/pdn-identity#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .

<http://mee.foundation/ontologies/pdn-identity/shapes> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/pdn-identity> ;
    owl:versionInfo "Version 1.1.1 - rename PDNidentity to PDNidentifier"@en ;
    rdfs:label "PDN Identity Ontology SHACL Validation Shapes"@en ;
    rdfs:comment """SHACL validation shapes for the PDN Identity Ontology.
                    Validates that identity:Individual, identity:Group, and identity:Organization
                    instances are well-formed PDN identity nodes."""@en .


#################################################################
#  PDN Identity
#################################################################

:HasPDNidentifierDomainShape
    a sh:NodeShape ;
    sh:targetSubjectsOf identity:hasPDNidentifier ;
    sh:or (
        [ sh:class persona:Person ]
        [ sh:class g:Group ]
        [ sh:class o:Organization ]
    ) ;
    sh:message "identity:hasPDNidentifier may only be used by persona:Person, g:Group, or o:Organization individuals."@en .


#################################################################
#  PDN Identity
#################################################################

:PDNidentifierShape
    a sh:NodeShape ;
    sh:targetClass identity:PDNidentifier ;
    sh:message "PDNidentifier validation: must be typed as one of the known identity subclasses."@en ;
    sh:or (
        [ sh:class identity:Individual ]
        [ sh:class identity:Group ]
        [ sh:class identity:Organization ]
    ) ;
    sh:message "A PDNidentifier must be typed as identity:Individual, identity:Group, or identity:Organization."@en .
