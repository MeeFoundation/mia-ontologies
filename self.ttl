@prefix : <http://www.example.org/mee#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mee> .

<http://www.example.org/mee> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    owl:imports <http://www.example.org/mee/citibank> ;
    owl:imports <http://www.example.org/mee/boston> ;
    owl:imports <http://www.example.org/mee/paradise> ;
    owl:imports <http://www.example.org/mee/family> ;
    owl:imports <http://www.example.org/mee/colleagues> ;
    owl:imports <http://www.example.org/mee/att> ;
    owl:imports <http://www.example.org/mee/ssa> ;
    owl:imports <http://www.example.org/mee/google> ;
    owl:imports <http://www.example.org/mee/texas-birth-certificate> ;
    dc:date "2026-04-12"^^xsd:date ;
    owl:versionInfo "Version 3.0.33 - import all context files for Protege auto-loading"@en ;
    rdfs:label "Alice Walker - Selfness"@en ;
    rdfs:comment """Alice Walker's selfness — the essential individuality and sense of selfhood from which
                    context-specific Personas (whonesses) are correlated.

                    Person Details:
                    - Height: 68 inches
                    - Eye Color: Blue
                    - Hair Color: Grey
                    - Mother: Paula Walker

                    Correlated Personas:
                    - :Alice_Walker-Citibank  (citibank.ttl)  — Citibank financial relationship
                    - :Alice_Walker-Boston    (boston.ttl)    — Boston residence (2020-2025)
                    - :Alice_Walker-Paradise  (paradise.ttl)  — Paradise residence (2025-present)
                    - :Alice_Walker-Family      (family.ttl)      — family relationships
                    - :Alice_Walker-Colleagues (colleagues.ttl) — colleague relationships
                    - :Alice_Walker-ATT        (att.ttl)        — AT&T phone account
                    - :Alice_Walker-SSA        (ssa.ttl)        — Social Security Administration
                    - :Alice_Walker-Google                (google.ttl)               — Google account (Gmail)
                    - :Alice_Walker-TexasBirthCertificate (texas-birth-certificate.ttl) — legal name record"""@en .


#################################################################
#    Alice Walker - Person Instance
#################################################################

###  Person: Alice Walker
:Alice_Walker-Self rdf:type owl:NamedIndividual ,
                       <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Alice Walker"@en ;
    rdfs:comment "Alice Walker's selfness — the central identity individual."@en ;

    # PHYSICAL CHARACTERISTICS
    
    <http://purl.obolibrary.org/obo/BFO_0000196> :Alice_Height ;               # bearer of → Height quality
    <http://purl.obolibrary.org/obo/BFO_0000196> :Alice_Height_Measurement ;  # bearer of → Height measurement ICE

    <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Eye Color
        rdf:type cco:ent00000040 ;  # Blue Eye Color
        rdfs:comment "Eye color: Blue"@en
    ] ;

    <http://purl.obolibrary.org/obo/BFO_0000178> [  # has continuant part → Scalp Hair
        rdf:type cco:ont00000058 ;  # Scalp Hair
        <http://purl.obolibrary.org/obo/BFO_0000196> [  # bearer of → Hair Color
            rdf:type cco:ont00000026 ;  # Hair Color
            <https://purl.org/cco/ont00001765> "Grey" ;  # has text value
            rdfs:comment "Hair color: Grey"@en
        ]
    ] ;

    # CAREER ROLES

    <http://purl.obolibrary.org/obo/BFO_0000196> :FounderOfXYZ ;    # bearer of
    <http://purl.obolibrary.org/obo/BFO_0000196> :EmployeeOfAcme ;  # bearer of

    # FAMILY RELATIONSHIPS

    cco:ont00001780 :Paula_Walker-Self ;  # has mother

    # CORRELATED PERSONAS (whonesses)

    persona:correlation :Alice_Walker-Citibank ;
    persona:correlation :Alice_Walker-Boston ;
    persona:correlation :Alice_Walker-Paradise ;
    persona:correlation :Alice_Walker-Family ;
    persona:correlation :Alice_Walker-Colleagues ;
    persona:correlation :Alice_Walker-ATT ;
    persona:correlation :Alice_Walker-SSA ;
    persona:correlation :Alice_Walker-Google ;
    persona:correlation :Alice_Walker-TexasBirthCertificate .



#################################################################
#    Height Measurement
#################################################################

:Alice_Height rdf:type owl:NamedIndividual ,
                       <https://purl.org/cco/ont00000967> ;  # Height (CCO Quality)
    rdfs:label "Alice Walker's height"@en .

:Alice_Height_Measurement rdf:type owl:NamedIndividual ,
                                   <https://purl.org/cco/ont00001022> ;  # Ratio Measurement ICE
    <https://purl.org/cco/ont00001983> :Alice_Height ;    # is a ratio measurement of
    <https://purl.org/cco/ont00001863> <https://purl.org/cco/ont00001677> ;  # uses measurement unit: Inch
    <https://purl.org/cco/ont00001769> "68"^^xsd:decimal .  # has decimal value


#################################################################
#    Paula Walker - Person Instance (Alice's mother)
#################################################################

:Paula_Walker-Self rdf:type owl:NamedIndividual ,
                           <https://purl.org/cco/ont00001262> ;  # Person
    rdfs:label "Paula Walker"@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → GivenName
        rdf:type cco:ent00000002 ;
        <https://purl.org/cco/ont00001765> "Paula"
    ] ;

    <https://purl.org/cco/ont00001879> [  # designated by → FamilyName
        rdf:type cco:ent00000004 ;
        <https://purl.org/cco/ont00001765> "Walker"
    ] ;

    persona:correlation :Paula_Walker-Family .


#################################################################
#    Career Roles
#################################################################

:XYZ_Corp rdf:type owl:NamedIndividual ,
                   cco:ont00001180 ;  # Organization (CCO)
    rdfs:label "XYZ Corp"@en .

:Acme_Corp rdf:type owl:NamedIndividual ,
                    cco:ont00001180 ;  # Organization (CCO)
    rdfs:label "Acme Corp"@en .

:FounderOfXYZ rdf:type owl:NamedIndividual ,
                       persona:Founder ;
    rdfs:label "Founder of XYZ"@en ;
    persona:roleInOrganization :XYZ_Corp .

:EmployeeOfAcme rdf:type owl:NamedIndividual ,
                         persona:Employee ;
    rdfs:label "Employee of Acme"@en ;
    persona:roleInOrganization :Acme_Corp .

:Bob_EmployeeOfAcme rdf:type owl:NamedIndividual ,
                             persona:Employee ;
    rdfs:label "Bob Johnston's Employee of Acme role"@en ;
    persona:roleInOrganization :Acme_Corp .


#################################################################
#    PATTERN NOTES
#################################################################

# ADDRESS HISTORY PATTERN:
# ------------------------
# Track N addresses over a person's lifetime with temporal bounds.
#
# Each address designation has:
# - Person (BFO has participant)
# - Address (CCO designated by)
# - Time interval (BFO occupies temporal region)
#   - Start date (required)
#   - End date (optional - absence = current address)
#
# Example queries:
# - "Where did Alice live in 2023?" → Boston address
# - "Where does Alice currently live?" → Paradise (no end date)
# - "When did Alice live in Boston?" → 2020-01-01 to 2025-08-31
# - "List all of Alice's addresses" → Boston, Paradise
#
# Extensible for future needs:
# - Multiple simultaneous addresses (add type/role property)
# - Move events (add Act of Change of Residence instances)
# - Address roles (mailing, billing, legal - add properties)
