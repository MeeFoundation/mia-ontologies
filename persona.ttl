@prefix : <http://mee.foundation/ontologies/persona#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://mee.foundation/ontologies/persona> .

<http://mee.foundation/ontologies/persona> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/persona/2.3.0> ;
    owl:imports <https://purl.org/cco/person> ;
    owl:imports <https://purl.org/cco/address> ;
    owl:imports <https://purl.org/cco/staging> ;
    dc:date "2026-04-12"^^xsd:date ;
    owl:versionInfo "Version 3.0.23 - drop hasPhysicalRepresentation; use BFO_0000101 (is carrier of) directly"@en ;
    rdfs:label "Persona Ontology"@en ;
    rdfs:comment """Persona Ontology for the Mee Identity Agent.
                    
                    This application ontology extends PersonOntology, AddressOntology, 
                    and StagingOntology for the Mee identity agent 
                    
                    ARCHITECTURE:
                    This application ontology serves as:
                    1. Aggregation point (imports 3 domain ontologies)
                    2. Documentation (annotations show which classes Persona uses)
                    3. Extension point (Persona-specific terms: future: accounts, service providers)
                    
                    GOVERNANCE MODEL:
                    - Domain ontologies (Person, Address, Staging): Import unchanged
                    - Persona extensions: Added here, may be promoted to domain ontologies if proven useful
                    - Application-specific patterns documented via usage annotations
                    
                    FEATURES:
                    - Defines a BirthCertificate kind of Persona with a peer name architecture (not hierarchical PersonName)
                    - Slash URIs (content negotiation enabled)
                    - International standards alignment (Schema.org, FHIR, OpenID)
                    - Address history tracking (N addresses over lifetime with temporal bounds)
                    """@en ;

    # Document which domain classes this application uses
    persona:usesRequiredClass cco:ent00000002 ,  # GivenName
                              cco:ent00000004 ,  # FamilyName
                              cco:ent00000008 ,  # SocialSecurityNumber
                              cco:ent00000010 ,  # USPostalAddress
                              cco:ent00000023 ,  # TelephoneNumber
                              cco:ent00000024 ;  # EmailAddress

    persona:usesOptionalClass cco:ent00000001 ,  # FullName
                              cco:ent00000003 ,  # AdditionalName (middle name)
                              cco:ent00000005 ,  # Suffix (Jr., Sr., etc.)
                              cco:ent00000006 ,  # AlternateName
                              cco:ent00000016 ,  # AddressDesignation
                              cco:ent00000051 ,  # Debit Card
                              cco:ent00000052 ,  # Credit Card Number (PAN)
                              cco:ent00000053 ,  # CVV
                              cco:ent00000054 ;  # Expiration Date Identifier

    # Document CCO classes used directly (note: use full IRIs, not cco: prefix)
    persona:usesCCOClass <https://purl.org/cco/ont00001262> ,  # Person
                         <https://purl.org/cco/ont00001331> ,  # Legal Name
                         <https://purl.org/cco/ont00000990> ,  # Nickname
                         <https://purl.org/cco/ont00000033> ,  # Online Service Account (StagingOntology)
                         <https://purl.org/cco/ont00000995> ,  # MaterialArtifact
                         <https://purl.org/cco/ont00000020> ,  # Container
                         <https://purl.org/cco/ont00000958> ;  # Information Content Entity

    # Document which properties this application uses (note: use full IRIs)
    persona:usesCCOProperty <https://purl.org/cco/ont00001879> ,            # designated by
                            <http://purl.obolibrary.org/obo/BFO_0000178> ,  # has continuant part
                            <https://purl.org/cco/ont00001765> ,            # has text value
                            <http://purl.obolibrary.org/obo/BFO_0000196> ,  # bearer of
                            <http://purl.obolibrary.org/obo/BFO_0000153> ,  # occupies temporal region
                            <http://purl.obolibrary.org/obo/BFO_0000139> ,  # has participant
                            <https://purl.org/cco/ent00000045> ,            # holds user account
                            <https://purl.org/cco/ent00000034> ,            # has service name
                            <https://purl.org/cco/ent00000035> ,            # has user handle
                            <https://purl.org/cco/ent00000036> ,            # has service URI
                            <https://purl.org/cco/ont00001801> ,            # is subject of (parent of hasPersona)
                            <http://purl.obolibrary.org/obo/BFO_0000101> .  # is carrier of (PhysicalCard → Persona)


#################################################################
#    Annotation Properties for Usage Documentation
#################################################################

persona:usesRequiredClass rdf:type owl:AnnotationProperty ;
    rdfs:label "uses required class"@en ;
    rdfs:comment """Indicates a class from domain ontologies that this application REQUIRES.
                    These classes are mandatory in Persona's SHACL validation."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range owl:Class .

persona:usesOptionalClass rdf:type owl:AnnotationProperty ;
    rdfs:label "uses optional class"@en ;
    rdfs:comment """Indicates a class from domain ontologies that this application OPTIONALLY uses.
                    These classes are allowed but not required in Persona's SHACL validation."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range owl:Class .

persona:usesCCOClass rdf:type owl:AnnotationProperty ;
    rdfs:label "uses CCO class"@en ;
    rdfs:comment """Indicates a class from CCO core ontologies that this application uses directly
                    (not subclassed in domain ontologies). Values are full IRIs like 
                    <https://purl.org/cco/ont00001262>."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range owl:Class .

persona:usesCCOProperty rdf:type owl:AnnotationProperty ;
    rdfs:label "uses CCO property"@en ;
    rdfs:comment """Indicates an object or data property from CCO that this application uses.
                    Values are full IRIs like <https://purl.org/cco/ont00001879>."""@en ;
    rdfs:domain owl:Ontology .

persona:usagePattern rdf:type owl:AnnotationProperty ;
    rdfs:label "usage pattern"@en ;
    rdfs:comment """Describes how this application uses a particular class or property."""@en ;
    rdfs:domain owl:Class .


#################################################################
#    Persona - a context-specific information profile of a Person
#################################################################
persona:Persona rdf:type owl:Class ;
    rdfs:subClassOf <https://purl.org/cco/ont00000958> ;  # Information Content Entity
    rdfs:label "Persona"@en ;
    rdfs:comment """An Information Content Entity that represents how a Person appears
                    in the context of a specific interaction — with a company, government
                    agency, another person, or a group of people. A Persona is not itself
                    a Person; it is a profile, or whoness, that is about a Person.
                    A Person may have multiple Personas, linked via persona:hasPersona."""@en .

#################################################################
#    hasPersona property - links a Person to a Persona (ICE)
#################################################################
persona:hasPersona rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf <https://purl.org/cco/ont00001801> ;  # is subject of (Entity → ICE)
    rdfs:domain <https://purl.org/cco/ont00001262> ;  # Person (selfness)
    rdfs:range persona:Persona ;
    rdfs:label "has persona"@en ;
    rdfs:comment """Links a Person's selfness to one of their context-specific Personas
                    (whonesses). The selfness is the authoritative identity; each Persona
                    is an Information Content Entity that represents that person within a
                    particular interaction context."""@en .

#################################################################
#    contextType property  
#################################################################    
persona:contextType rdf:type owl:AnnotationProperty ;
    rdfs:label "context type"@en ;
    rdfs:comment """Tags a context ontology (file) with the kind of relationship it represents —
                    e.g. persona:Company, persona:Federal, persona:Municipality.
                    Applied to the ontology IRI, not to the Persona individual."""@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range persona:Context .


#################################################################
#    Other properties
#################################################################

persona:hasSocialNetwork rdf:type owl:ObjectProperty ;
    rdfs:domain persona:Persona ;
    rdfs:range cco:ont00001183 ;    # Social Network
    rdfs:label "has social network"@en ;
    rdfs:comment """Links a Persona to a Social Network — the set of other people
                    with whom the person has relationships in that context. The Persona is
                    not a member of the network; the network contains only the people they
                    relate to."""@en .

persona:holdsPaymentCard rdf:type owl:ObjectProperty ;
    rdfs:domain persona:Persona ;
    rdfs:range cco:ent00000049 ;    # Payment Card
    rdfs:label "holds payment card"@en ;
    rdfs:comment "Links a Persona to a Payment Card (credit, debit, or other) it records."@en .


#################################################################
#    BirthCertificate Persona — a Persona subtype with name constraints
#################################################################
persona:BirthCertificate rdf:type owl:Class ;
    rdfs:subClassOf persona:Persona ;
    rdfs:label "Birth Certificate Persona"@en ;
    rdfs:comment """A Persona whose purpose is to carry a person's legal birth certificate
                    name record. Subclass of Persona (not of Context) so that SHACL can
                    target it directly with sh:targetClass to enforce name constraints."""@en .


#################################################################
#    Banking-related 
#################################################################

persona:CheckingAccount rdf:type owl:Class ;
    rdfs:label "Checking Account"@en ;
    rdfs:comment "A bank checking account held by a person, linked to a debit card."@en .

persona:CheckingAccountNumber rdf:type owl:Class ;
    rdfs:label "Checking Account Number"@en ;
    rdfs:comment "An identifier designating a bank checking account. Used via designated by (ont00001879)."@en .

persona:RoutingNumber rdf:type owl:Class ;
    rdfs:label "Routing Number"@en ;
    rdfs:comment "An ABA routing transit number identifying the financial institution. Used via designated by (ont00001879)."@en .

persona:holdsBankAccount rdf:type owl:ObjectProperty ;
    rdfs:domain persona:Persona ;
    rdfs:range persona:CheckingAccount ;
    rdfs:label "holds bank account"@en ;
    rdfs:comment "Links a Persona to a bank account it records."@en .

persona:accessesBankAccount rdf:type owl:ObjectProperty ;
    rdfs:domain cco:ent00000051 ;  # Debit Card
    rdfs:range persona:CheckingAccount ;
    rdfs:label "accesses bank account"@en ;
    rdfs:comment "Links a DebitCard to the CheckingAccount it draws funds from."@en .

persona:hasPassword rdf:type owl:DatatypeProperty ;
    rdfs:domain cco:ent00000033 ;  # Online Service Account
    rdfs:range xsd:string ;
    rdfs:label "has password"@en ;
    rdfs:comment "The password credential for an online service account."@en .


#################################################################
#    Physical Belongings
#################################################################

persona:PhysicalCard rdf:type owl:Class ;
    rdfs:subClassOf <https://purl.org/cco/ont00000995> ;  # MaterialArtifact
    rdfs:label "Physical Card"@en ;
    rdfs:comment "A physical card (e.g. driver's license, health insurance card) carried in a wallet."@en .

persona:Wallet rdf:type owl:Class ;
    rdfs:subClassOf <https://purl.org/cco/ont00000020> ;  # Container (subclass of MaterialArtifact)
    rdfs:label "Wallet"@en ;
    rdfs:comment "A physical wallet that holds cards and other personal documents."@en .

persona:DriversLicense rdf:type owl:Class ;
    rdfs:subClassOf persona:PhysicalCard ;
    rdfs:label "Driver's License"@en ;
    rdfs:comment "A state-issued driver's license card."@en .

persona:HealthInsuranceCard rdf:type owl:Class ;
    rdfs:subClassOf persona:PhysicalCard ;
    rdfs:label "Health Insurance Card"@en ;
    rdfs:comment "A physical health insurance membership card."@en .

persona:holdsWallet rdf:type owl:ObjectProperty ;
    rdfs:domain persona:Persona ;
    rdfs:range persona:Wallet ;
    rdfs:label "holds wallet"@en ;
    rdfs:comment "Links a Persona to the physical wallet they carry."@en .

persona:hasImageScan rdf:type owl:DatatypeProperty ;
    rdfs:domain persona:PhysicalCard ;
    rdfs:range xsd:anyURI ;
    rdfs:label "has image scan"@en ;
    rdfs:comment "A URI pointing to a scanned image of the physical card."@en .


#################################################################
#    Context Hierarchy
#    Context subclasses are used as values for the persona:contextType
#    annotation property on ontology IRIs (context files), not as
#    rdf:type assertions on Persona individuals.
#################################################################

persona:Context rdf:type owl:Class ;
    rdfs:label "Context"@en ;
    rdfs:comment """Controlled vocabulary for the kind of interaction context a context file represents.
                    Used as the value of persona:contextType on ontology IRIs."""@en .

persona:Career rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Career"@en ;
    rdfs:comment "Professional roles, employment history, and career relationships."@en .

persona:Company rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Company"@en ;
    rdfs:comment "Relationship with a specific company, bank, or other institution."@en .

persona:Government rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Government"@en ;
    rdfs:comment "Government-issued credentials, tax records, and civic relationships."@en .

persona:Federal rdf:type owl:Class ;
    rdfs:subClassOf persona:Government ;
    rdfs:label "Federal"@en ;
    rdfs:comment "Federal government context (e.g. passport, federal tax records)."@en .

persona:State rdf:type owl:Class ;
    rdfs:subClassOf persona:Government ;
    rdfs:label "State"@en ;
    rdfs:comment "State government context (e.g. driver's license, state tax records)."@en .

persona:Municipality rdf:type owl:Class ;
    rdfs:subClassOf persona:Government ;
    rdfs:label "Municipality"@en ;
    rdfs:comment "Municipal government context (e.g. local permits, library card)."@en .

persona:Possession rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Possession"@en ;
    rdfs:comment "Owned assets, property, vehicles, and other possessions."@en .

persona:Project rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Project"@en ;
    rdfs:comment "Involvement in a specific project or initiative."@en .

persona:Event rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Event"@en ;
    rdfs:comment "Participation in or relationship to a specific event."@en .

persona:Learning rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Learning"@en ;
    rdfs:comment "Educational experiences, courses, and certifications."@en .

persona:Topic rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "Topic"@en ;
    rdfs:comment "Interest in or expertise around a specific subject area."@en .

persona:People rdf:type owl:Class ;
    rdfs:subClassOf persona:Context ;
    rdfs:label "People"@en ;
    rdfs:comment "Interactions with all kinds of people."@en .

persona:Family rdf:type owl:Class ;
    rdfs:subClassOf persona:People ;
    rdfs:label "Family"@en ;
    rdfs:comment "Interactions with family members."@en .

persona:Friends rdf:type owl:Class ;
    rdfs:subClassOf persona:People ;
    rdfs:label "Interactions with friends"@en ;
    rdfs:comment "."@en .

persona:Consultants rdf:type owl:Class ;
    rdfs:subClassOf persona:People ;
    rdfs:label "Consultants"@en ;
    rdfs:comment "Interactions with consultants who provide services."@en .

persona:Colleagues rdf:type owl:Class ;
    rdfs:subClassOf persona:People ;
    rdfs:label "Colleagues"@en ;
    rdfs:comment "Interactions with others with whom you work."@en .

persona:Other rdf:type owl:Class ;
    rdfs:subClassOf persona:People ;
    rdfs:label "Other"@en ;
    rdfs:comment "Interactions with a person not fitting Family, Friends, Colleagues, or Consultants."@en .


#################################################################
#    Usage Pattern Documentation on Specific Classes
#################################################################

cco:ent00000001
    persona:usagePattern """Persona accepts FullName as complete string alternative 
                            to structured components. SHACL validation: EITHER FullName OR 
                            (GivenName + FamilyName) required."""@en .

cco:ent00000002
    persona:usagePattern """Legal first name. Required if FullName not provided. 
                            Multiple GivenNames allowed (e.g., 'Mary Anne')."""@en .

cco:ent00000004
    persona:usagePattern """Legal last/surname. Required if FullName not provided."""@en .

cco:ent00000003
    persona:usagePattern """Middle names or additional given names. Optional. 
                            Use for names person goes by that aren't their legal first name."""@en .

cco:ent00000006
    persona:usagePattern """Any alternative form of the person's name (nicknames, 
                            preferred names, previous names). Optional."""@en .

cco:ent00000008
    persona:usagePattern """US SSN in format NNN-NN-NNNN. Required for identity verification."""@en .

cco:ent00000010
    persona:usagePattern """Primary residential address. Required. Must include street, 
                            city, state, ZIP. Country optional."""@en .

cco:ent00000024
    persona:usagePattern """Primary email address. Required for account access."""@en .

cco:ent00000023
    persona:usagePattern """Primary phone number. Required. Prefer E.164 format."""@en .

cco:ent00000016
    persona:usagePattern """Used to track address history with temporal bounds. Each designation
                            represents a person living at an address during a specific time period.
                            Use BFO 'occupies temporal region' to specify the time interval with
                            start and optional end dates. An open-ended interval (no end date)
                            indicates current address. Supports N addresses over a person's lifetime."""@en .

cco:ent00000051
    persona:usagePattern """Debit card held by a Person, linked via persona:holdsPaymentCard.
                            Designated by a CreditCardNumber (ent00000052), CVV (ent00000053),
                            and ExpirationDateIdentifier (ent00000054) using ont00001879
                            (designated by)."""@en .
