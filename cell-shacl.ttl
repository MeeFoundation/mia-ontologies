@prefix : <http://www.example.org/cell-shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix cell: <http://mee.foundation/ontologies/cell#> .
@prefix context: <http://mee.foundation/ontologies/context#> .

<http://www.example.org/cell-shapes> rdf:type owl:Ontology ;
    owl:versionInfo "Version 3.4.0 - removed the cell:sbs constraint from :CellShape and added cell:sc-context (values must be a context:SCcontext), matching cell.ttl 3.4.0's replacement of cell:sbs/obs/sbo/obo with the single multi-valued cell:sc-context. Removed :OnePartyShape, :TwoPartyShape, and :ThreePlusPartyShape entirely: they existed solely to constrain obs/sbo/obo cardinality by party count, and cell:sc-context (domain the broader cell:Cell, unconstrained cardinality) carries no such per-party-count distinction. (Version 3.3.0 - removed the cell:catNode constraint from :CellShape: the property was removed from cell.ttl 3.3.0 in favor of cat:cell (category.ttl 1.6.0), asserted on the node instead. A cell is no longer required to carry any link to its tree position at all — see category-shacl.ttl's new :NodeShape constraint on cat:cell instead. (v3.2.0 - cell:catNode is now required (exactly one value) on :CellShape, not just optional, since cat:forCell was removed from category.ttl 1.2.0 — every cell, canonical or copy, now depends on its own cell:catNode to be reachable from its tree position at all. (v3.1.0 - added cell:catNode (at most one value, must be a cat:Node) to :CellShape, matching cell.ttl 3.1.0. v3.0.0 - split alongside cell.ttl 3.0.0: :CellShape now targets the renamed cell:Cell (formerly cell:Parties) and absorbs the graph/note/folder constraints (domain moved here from the old cell:Cell, now cat:Category — see category-shacl.ttl); cellType/child/copiedFrom constraints moved out to category-shacl.ttl. cell:label re-added (distinct from cat:label) as a class-level default display name on concrete cell:Cell subtypes.)))"@en ;
    rdfs:label "Cell Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for cell:Cell DataBook instances (the content facet of a cell) in the Cell Ontology."@en .


#################################################################
#  Cell
#  cell:Cell (formerly cell:Parties) classifies every cell instance
#  by total party count. num-parties/sc-context/graph/note/folder
#  all have domain cell:Cell — cell:sc-context carries no per-party-
#  count cardinality distinction, unlike the sbs/obs/sbo/obo
#  properties it replaced.
#################################################################

:CellShape
    a sh:NodeShape ;
    sh:targetClass cell:Cell ;
    sh:message "Cell validation."@en ;

    # cell:graph — at most one plain Context link
    sh:property [
        sh:path cell:graph ;
        sh:maxCount 1 ;
        sh:message "A cell may link to at most one plain Context via cell:graph."@en
    ] ;

    # cell:sc-context — zero or more, each a context:SCcontext
    sh:property [
        sh:path cell:sc-context ;
        sh:class context:SCcontext ;
        sh:message "A cell's cell:sc-context values, if any, must each be a context:SCcontext."@en
    ] ;

    # cell:num-parties — at most one value, and if present must be
    # a concrete cell:Cell subclass. Not required (sh:minCount
    # omitted): the invisible tree roots have no num-parties.
    sh:property [
        sh:path cell:num-parties ;
        sh:maxCount 1 ;
        sh:in ( "OneParty" "TwoParty" "ThreePlusParty" ) ;
        sh:message "A cell's cell:num-parties, if present, must be one of OneParty, TwoParty, ThreePlusParty."@en
    ] ;

    # cell:note — at most one markdown notes file path
    sh:property [
        sh:path cell:note ;
        sh:maxCount 1 ;
        sh:message "A cell may have at most one cell:note value."@en
    ] ;

    # cell:folder — at most one associated files folder path
    sh:property [
        sh:path cell:folder ;
        sh:maxCount 1 ;
        sh:message "A cell may have at most one cell:folder value."@en
    ] .
