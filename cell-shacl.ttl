@prefix : <http://mee.foundation/ontologies/cell/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix cell: <http://mee.foundation/ontologies/cell#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix p: <http://mee.foundation/ontologies/persona#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .

<http://mee.foundation/ontologies/cell/shapes> rdf:type owl:Ontology ;
    owl:versionInfo "Version 3.5.0 - renamed this ontology's IRI from http://www.example.org/cell-shapes to http://mee.foundation/ontologies/cell/shapes: only example data should be grounded under www.example.org — foundational ontologies and their SHACL companions belong under mee.foundation/ontologies (see CLAUDE.md's new IRI-root integrity check)."@en ;
    rdfs:label "Cell Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for cell:Cell DataBook instances (the content facet of a cell) in the Cell Ontology."@en .


#################################################################
#  Cell
#  cell:Cell (formerly cell:Parties) classifies every cell instance
#  by total party count. parties/sc-context/graph/note/folder
#  all have domain cell:Cell — cell:sc-context carries no per-party-
#  count cardinality distinction, unlike the sbs/obs/sbo/obo
#  properties it replaced.
#################################################################

:CellShape
    a sh:NodeShape ;
    sh:targetClass cell:Cell ;
    sh:message "Cell validation."@en ;

    # cell:graph — at most one plain Context link
    sh:property [
        sh:path cell:graph ;
        sh:maxCount 1 ;
        sh:message "A cell may link to at most one plain Context via cell:graph."@en
    ] ;

    # cell:sc-context — zero or more, each a context:SCcontext
    sh:property [
        sh:path cell:sc-context ;
        sh:class context:SCcontext ;
        sh:message "A cell's cell:sc-context values, if any, must each be a context:SCcontext."@en
    ] ;

    # cell:creator — at most one value, must be a Person, Group, or Organization
    sh:property [
        sh:path cell:creator ;
        sh:maxCount 1 ;
        sh:or ( [ sh:class p:Person ] [ sh:class g:Group ] [ sh:class o:Organization ] ) ;
        sh:message "A cell's cell:creator, if present, must be a single p:Person, g:Group, or o:Organization."@en
    ] ;

    # cell:parties — exactly one value, must be the class
    # cell:OneParty, cell:TwoParty, or cell:ThreePlusParty itself
    # (class-value punning, not a string). Required: every cell:Cell
    # instance is typed as one of these three by definition.
    sh:property [
        sh:path cell:parties ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( cell:OneParty cell:TwoParty cell:ThreePlusParty ) ;
        sh:message "A cell's cell:parties is required and must be the class cell:OneParty, cell:TwoParty, or cell:ThreePlusParty."@en
    ] ;

    # cell:note — at most one markdown notes file path
    sh:property [
        sh:path cell:note ;
        sh:maxCount 1 ;
        sh:message "A cell may have at most one cell:note value."@en
    ] ;

    # cell:folder — at most one associated files folder path
    sh:property [
        sh:path cell:folder ;
        sh:maxCount 1 ;
        sh:message "A cell may have at most one cell:folder value."@en
    ] .
