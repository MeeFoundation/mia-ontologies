@prefix : <http://www.example.org/context-shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix context: <http://mee.foundation/ontologies/context#> .

<http://www.example.org/context-shapes> rdf:type owl:Ontology ;
    owl:versionInfo "Version 1.0.3 - add origin-type (required, open-ended) and category-type (optional, enum) constraints"@en ;
    rdfs:label "Context Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for category DataBook instances in the Context Ontology."@en .


#################################################################
#  Category
#  All category instances. sbs/obs/sbo/obo all have domain
#  context:Category (not context:UserDefined or context:Parties),
#  so all four constraints target context:Category.
#################################################################

:CategoryShape
    a sh:NodeShape ;
    sh:targetClass context:Category ;
    sh:message "Category validation."@en ;

    # context:sbs — at most one SBS context link per category
    sh:property [
        sh:path context:sbs ;
        sh:maxCount 1 ;
        sh:message "A category may link to at most one SBScontext via context:sbs."@en
    ] ;

    # context:obs — at most one OBS context link
    sh:property [
        sh:path context:obs ;
        sh:maxCount 1 ;
        sh:message "A category may link to at most one OBScontext via context:obs."@en
    ] ;

    # context:sbo — at most one SBO context link
    sh:property [
        sh:path context:sbo ;
        sh:maxCount 1 ;
        sh:message "A category may link to at most one SBOcontext via context:sbo."@en
    ] ;

    # context:origin-type — required exactly once. No sh:in enum: the
    # value should be "UserDefined" or a context:Predefined subclass
    # name (e.g. "PersonPredefined", "OrgPredefined"), but is
    # intentionally open-ended so future predefined kinds don't
    # require updating this shape.
    sh:property [
        sh:path context:origin-type ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A category must have exactly one context:origin-type value: \"UserDefined\" or a context:Predefined subclass name (e.g. \"PersonPredefined\", \"OrgPredefined\")."@en
    ] ;

    # context:category-type — at most one value, and if present must be
    # a context:Parties subclass. Not required (sh:minCount omitted):
    # the invisible tree roots have no category-type.
    sh:property [
        sh:path context:category-type ;
        sh:maxCount 1 ;
        sh:in ( "OneParty" "TwoParty" "MultiParty" ) ;
        sh:message "A category's context:category-type, if present, must be one of OneParty, TwoParty, MultiParty."@en
    ] .

    # context:obo — 0..N (no maxCount constraint)
