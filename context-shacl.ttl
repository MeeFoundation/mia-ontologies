@prefix : <http://mee.foundation/ontologies/context/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix g: <http://mee.foundation/ontologies/group#> .
@prefix o: <http://mee.foundation/ontologies/organization#> .

<http://mee.foundation/ontologies/context/shapes> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    owl:versionInfo "Version 1.1.0 - removed :ContextShape entirely: a context DataBook should not carry a creator property at all, cell:creator least of all — that was a modeling mistake (cell.ttl 3.5.1 reverted cell:creator's domain back to cell:Cell alone). Removed the now-unused cell: prefix."@en ;
    rdfs:label "Context Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for context.ttl's context:SCcontext DataBook instances."@en .


#################################################################
#  Context DataBook (context:SCcontext)
#  Validates the subject/claimant classification fields on every
#  context DataBook
#################################################################

:SCcontextShape
    a sh:NodeShape ;
    sh:targetClass context:SCcontext ;
    sh:message "SCcontext validation: subject and claimant must each be exactly one Person, Group, or Organization."@en ;
    sh:property [
        sh:path context:subject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or ( [ sh:class persona:Person ] [ sh:class g:Group ] [ sh:class o:Organization ] ) ;
        sh:message "context:subject must have exactly one value, and it must be a persona:Person, g:Group, or o:Organization."@en
    ] ;
    sh:property [
        sh:path context:claimant ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or ( [ sh:class persona:Person ] [ sh:class g:Group ] [ sh:class o:Organization ] ) ;
        sh:message "context:claimant must have exactly one value, and it must be a persona:Person, g:Group, or o:Organization."@en
    ] .
