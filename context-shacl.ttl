@prefix : <http://mee.foundation/ontologies/context/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix context: <http://mee.foundation/ontologies/context#> .
@prefix identity: <http://mee.foundation/ontologies/identity#> .

<http://mee.foundation/ontologies/context/shapes> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/context> ;
    owl:versionInfo "Version 1.0.0 - initial"@en ;
    rdfs:label "Context Ontology SHACL Validation Shapes"@en ;
    rdfs:comment """SHACL validation shapes for the Context Ontology.

                    Targets context file ontology IRIs (any resource that bears a
                    context:contextCategory annotation) and validates that the three
                    required classification annotations are each present exactly once.

                    Note: context:contextCategory values are OWL classes (subclasses of
                    context:ContextCategory), not instances — so sh:class cannot be used
                    to validate them. Cardinality is validated; type is enforced by
                    the controlled vocabulary in context.ttl."""@en .


#################################################################
#  Context File Ontology
#  Targets any ontology IRI annotated with context:contextCategory.
#################################################################

:ContextFileShape
    a sh:NodeShape ;
    sh:targetSubjectsOf context:contextCategory ;
    sh:message "Context file ontology validation: contextCategory, assertedBy, and subject must each appear exactly once."@en ;

    # Exactly one contextCategory (value is a ContextCategory subclass IRI)
    sh:property [
        sh:path context:contextCategory ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "A context file ontology must have exactly one context:contextCategory annotation."@en
    ] ;

    # Exactly one assertedBy (value is a PDNidentity subclass IRI)
    sh:property [
        sh:path context:assertedBy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "A context file ontology must have exactly one context:assertedBy annotation."@en
    ] ;

    # Exactly one subject (value is a PDNidentity subclass IRI)
    sh:property [
        sh:path context:subject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "A context file ontology must have exactly one context:subject annotation."@en
    ] .
