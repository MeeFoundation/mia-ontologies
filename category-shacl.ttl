@prefix : <http://mee.foundation/ontologies/category/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix cat: <http://mee.foundation/ontologies/category#> .
@prefix cell: <http://mee.foundation/ontologies/cell#> .

<http://mee.foundation/ontologies/category/shapes> rdf:type owl:Ontology ;
    owl:versionInfo "Version 1.8.0 - removed :CategoryDefinedShape's sh:class cat:Category constraint on cat:category: a legal value is rdfs:subClassOf cat:Category, never rdf:type cat:Category, so the constraint could never be satisfied by any real data — first caught once category DataBook YAML frontmatter started being validated for real (see README's Validation section)."@en ;
    rdfs:label "Category Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for cat:Category/cat:Node DataBook instances (the classificatory and tree-position facets of a cell) in the Category Ontology."@en .


#################################################################
#  Category
#  cat:catType records a category's classification as a plain
#  string, on any category DataBook (canonical or copy).
#################################################################

:CategoryShape
    a sh:NodeShape ;
    sh:targetClass cat:Category ;
    sh:message "Category validation."@en ;

    # cat:catType — required exactly once. No sh:in enum: the value
    # is the local name of the cat:Category subclass this DataBook
    # canonically is (canonical) or was copied from (instance copy)
    # — e.g. "Family", "Consultants(org)" — or "Category" itself if
    # there is no more specific canonical counterpart. Intentionally
    # open-ended so new canonical subclasses don't require updating
    # this shape.
    sh:property [
        sh:path cat:catType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A category must have exactly one cat:catType value: the cat:Category subclass local name it is or was copied from, or \"Category\" itself."@en
    ] .

#################################################################
#  Node
#  Every cat:Node instance (Copy or UserDefined) has zero or more
#  cat:child links to more specific child nodes, and zero or more
#  cat:cell links to the cell:Cell(s) it holds.
#################################################################

:NodeShape
    a sh:NodeShape ;
    sh:targetClass cat:Node ;
    sh:message "Node validation."@en ;

    # cat:child — zero or more, each a cat:Node
    sh:property [
        sh:path cat:child ;
        sh:class cat:Node ;
        sh:message "A node's cat:child values, if any, must each be a cat:Node."@en
    ] ;

    # cat:cell — zero or more, each a cell:Cell. No minCount: not
    # every node necessarily has content yet, and no maxCount: the
    # relationship is many-to-one (many cells may share one node).
    sh:property [
        sh:path cat:cell ;
        sh:class cell:Cell ;
        sh:message "A node's cat:cell values, if any, must each be a cell:Cell."@en
    ] .

#################################################################
#  Label
#  cat:label applies to both cat:CategoryDefined and cat:UserDefined
#  — any node in a user's own instance tree, whether instantiated
#  from a canonical template or created directly.
#################################################################

:LabelShape
    a sh:NodeShape ;
    sh:targetClass cat:CategoryDefined, cat:UserDefined ;
    sh:message "Label validation."@en ;

    # cat:label — at most one display-name override
    sh:property [
        sh:path cat:label ;
        sh:maxCount 1 ;
        sh:message "A node may have at most one cat:label value."@en
    ] .

#################################################################
#  CategoryDefined
#  A cat:CategoryDefined node has at most one cat:category, pointing
#  at the cat:Category subclass it represents — this also records
#  which class it was effectively instantiated from, since
#  category.ttl 1.8.0 removed the separate
#  cat:Canonical/cat:copiedFrom mechanism.
#  (A user-created node with no canonical counterpart is a
#  cat:UserDefined instead, which carries no cat:category at all —
#  see :LabelShape above for the cat:label constraint shared by both.)
#################################################################

:CategoryDefinedShape
    a sh:NodeShape ;
    sh:targetClass cat:CategoryDefined ;
    sh:message "CategoryDefined node validation."@en ;

    # cat:category — at most one, pointing at a cat:Category subclass.
    # Not constrained to sh:class cat:Category: a legal value (e.g.
    # cat:BankingPayments) is rdfs:subClassOf cat:Category, never
    # rdf:type cat:Category — no leaf category class is ever asserted as
    # an *instance* of cat:Category, so sh:class here could never be
    # satisfied by any legitimate value. Checking "is a legal cat:Category
    # subclass" properly would need a SPARQL-based constraint walking
    # rdfs:subClassOf; cardinality alone is enforced here instead.
    sh:property [
        sh:path cat:category ;
        sh:maxCount 1 ;
        sh:message "A cat:CategoryDefined node may have at most one cat:category value."@en
    ] .
