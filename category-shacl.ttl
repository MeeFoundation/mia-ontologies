@prefix : <http://www.example.org/category-shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix cat: <http://mee.foundation/ontologies/category#> .

<http://www.example.org/category-shapes> rdf:type owl:Ontology ;
    owl:versionInfo "Version 1.0.0 - split out of context-shacl.ttl into its own file, cat: prefix"@en ;
    rdfs:label "Category Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for category DataBook instances in the Category Ontology."@en .


#################################################################
#  Category
#  All category instances. sbs/obs/sbo/obo all have domain
#  cat:Category (not cat:UserDefined or cat:Parties),
#  so all four constraints target cat:Category.
#################################################################

:CategoryShape
    a sh:NodeShape ;
    sh:targetClass cat:Category ;
    sh:message "Category validation."@en ;

    # cat:sbs — at most one SBS context link per category
    sh:property [
        sh:path cat:sbs ;
        sh:maxCount 1 ;
        sh:message "A category may link to at most one SBScontext via cat:sbs."@en
    ] ;

    # cat:obs — at most one OBS context link
    sh:property [
        sh:path cat:obs ;
        sh:maxCount 1 ;
        sh:message "A category may link to at most one OBScontext via cat:obs."@en
    ] ;

    # cat:sbo — at most one SBO context link
    sh:property [
        sh:path cat:sbo ;
        sh:maxCount 1 ;
        sh:message "A category may link to at most one SBOcontext via cat:sbo."@en
    ] ;

    # cat:origin-type — required exactly once. No sh:in enum: the
    # value should be "UserDefined" or a cat:Predefined subclass
    # name (e.g. "PersonPredefined", "OrgPredefined"), but is
    # intentionally open-ended so future predefined kinds don't
    # require updating this shape.
    sh:property [
        sh:path cat:origin-type ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A category must have exactly one cat:origin-type value: \"UserDefined\" or a cat:Predefined subclass name (e.g. \"PersonPredefined\", \"OrgPredefined\")."@en
    ] ;

    # cat:num-parties — at most one value, and if present must be
    # a cat:Parties subclass. Not required (sh:minCount omitted):
    # the invisible tree roots have no num-parties.
    sh:property [
        sh:path cat:num-parties ;
        sh:maxCount 1 ;
        sh:in ( "OneParty" "TwoParty" "MultiParty" ) ;
        sh:message "A category's cat:num-parties, if present, must be one of OneParty, TwoParty, MultiParty."@en
    ] .

    # cat:obo — 0..N (no maxCount constraint)
