@prefix : <http://www.example.org/category-shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix cat: <http://mee.foundation/ontologies/category#> .
@prefix cell: <http://mee.foundation/ontologies/cell#> .

<http://www.example.org/category-shapes> rdf:type owl:Ontology ;
    owl:versionInfo "Version 1.4.0 - added the cat:cell constraint to :NodeShape, matching category.ttl 1.6.0's reinstated cat:cell (domain cat:Node, range cell:Cell) — a node reaches its cell(s) directly now, reversing v1.2.0's removal of cat:forCell in favor of cell:catNode (which cell.ttl 3.3.0 has, in turn, removed). No minCount: a node may have zero, one, or many associated cells. (v1.3.0 - added cat:UserDefined (a third cat:Node subclass, alongside cat:Canonical and cat:Copy, for user-created nodes with no canonical counterpart), matching category.ttl 1.3.0. cat:label's constraint moved out of :CopyShape into a new shared :LabelShape (sh:targetClass cat:Copy, cat:UserDefined), matching cat:label's new union domain. (v1.2.0 - removed the cat:forCell constraint from :CanonicalShape, matching category.ttl 1.2.0 (cat:forCell removed entirely — every node reaches its cell via cell:catNode, asserted on the cell, not a forward link). v1.1.0 - split alongside category.ttl 1.1.0: :NodeShape (target cat:Node) now carries cat:child; new :CanonicalShape (target cat:Canonical) carries cat:forCell/cat:category; new :CopyShape (target cat:Copy) carries cat:copiedFrom/cat:label; :CategoryShape (target cat:Category) keeps only cat:catType))"@en ;
    rdfs:label "Category Ontology SHACL Validation Shapes"@en ;
    rdfs:comment "SHACL validation shapes for cat:Category/cat:Node DataBook instances (the classificatory and tree-position facets of a cell) in the Category Ontology."@en .


#################################################################
#  Category
#  cat:catType records a category's classification as a plain
#  string, on any category DataBook (canonical or copy).
#################################################################

:CategoryShape
    a sh:NodeShape ;
    sh:targetClass cat:Category ;
    sh:message "Category validation."@en ;

    # cat:catType — required exactly once. No sh:in enum: the value
    # is the local name of the cat:Category subclass this DataBook
    # canonically is (canonical) or was copied from (instance copy)
    # — e.g. "Family", "Consultants(org)" — or "Category" itself if
    # there is no more specific canonical counterpart. Intentionally
    # open-ended so new canonical subclasses don't require updating
    # this shape.
    sh:property [
        sh:path cat:catType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A category must have exactly one cat:catType value: the cat:Category subclass local name it is or was copied from, or \"Category\" itself."@en
    ] .

#################################################################
#  Node
#  Every cat:Node instance (Canonical, Copy, or UserDefined) has
#  zero or more cat:child links to more specific child nodes, and
#  zero or more cat:cell links to the cell:Cell(s) it holds.
#################################################################

:NodeShape
    a sh:NodeShape ;
    sh:targetClass cat:Node ;
    sh:message "Node validation."@en ;

    # cat:child — zero or more, each a cat:Node
    sh:property [
        sh:path cat:child ;
        sh:class cat:Node ;
        sh:message "A node's cat:child values, if any, must each be a cat:Node."@en
    ] ;

    # cat:cell — zero or more, each a cell:Cell. No minCount: not
    # every node necessarily has content yet, and no maxCount: the
    # relationship is many-to-one (many cells may share one node).
    sh:property [
        sh:path cat:cell ;
        sh:class cell:Cell ;
        sh:message "A node's cat:cell values, if any, must each be a cell:Cell."@en
    ] .

#################################################################
#  Label
#  cat:label applies to both cat:Copy and cat:UserDefined — any
#  node in a user's own instance tree, whether copied from a
#  canonical template or created directly — but not cat:Canonical.
#################################################################

:LabelShape
    a sh:NodeShape ;
    sh:targetClass cat:Copy, cat:UserDefined ;
    sh:message "Label validation."@en ;

    # cat:label — at most one display-name override
    sh:property [
        sh:path cat:label ;
        sh:maxCount 1 ;
        sh:message "A node may have at most one cat:label value."@en
    ] .

#################################################################
#  Canonical
#  A cat:Canonical has at most one cat:category (which cat:Category
#  subclass it represents) — the invisible tree roots, whose catType
#  falls back to the abstract root, carry none. Its cell:Cell(s), if
#  any, are validated by :NodeShape's cat:cell constraint above,
#  inherited from cat:Node rather than re-declared here.
#################################################################

:CanonicalShape
    a sh:NodeShape ;
    sh:targetClass cat:Canonical ;
    sh:message "Canonical node validation."@en ;

    # cat:category — at most one, pointing at a cat:Category subclass
    sh:property [
        sh:path cat:category ;
        sh:maxCount 1 ;
        sh:class cat:Category ;
        sh:message "A canonical node may have at most one cat:category value, and it must be a cat:Category."@en
    ] .

#################################################################
#  Copy
#  A cat:Copy has at most one cat:copiedFrom, pointing at the
#  cat:Canonical it was copied from. (A user-created node with no
#  canonical counterpart is a cat:UserDefined instead, which has no
#  cat:copiedFrom constraint of its own — see :LabelShape above for
#  the cat:label constraint shared by both.)
#################################################################

:CopyShape
    a sh:NodeShape ;
    sh:targetClass cat:Copy ;
    sh:message "Copy node validation."@en ;

    # cat:copiedFrom — at most one canonical-template reference
    sh:property [
        sh:path cat:copiedFrom ;
        sh:maxCount 1 ;
        sh:class cat:Canonical ;
        sh:message "A copy node may have at most one cat:copiedFrom value, and it must be a cat:Canonical."@en
    ] .
