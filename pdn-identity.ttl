@prefix identity: <http://mee.foundation/ontologies/pdn-identity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://mee.foundation/ontologies/pdn-identity> .

<http://mee.foundation/ontologies/pdn-identity> rdf:type owl:Ontology ;
    owl:versionIRI <http://mee.foundation/ontologies/pdn-identity/1.3.0> ;
    dc:date "2026-07-12"^^xsd:date ;
    owl:versionInfo "Version 1.3.0 - removed identity:hasPDNidentifier: never populated on any individual in the example data. Removed the owl:Restrictions that referenced it on g:Group/o:Organization (group.ttl, organization.ttl), the SHACL shapes constraining it (group-shacl.ttl, organization-shacl.ttl), and the :HasPDNidentifierDomainShape here that targeted it."@en ;
    rdfs:label "PDN Identity Ontology"@en ;
    rdfs:comment """PDN Identity Ontology for the Mee Identity Agent.
                    Defines the taxonomy of PDN node identifiers — the typed tokens that
                    allow a Person (Individual), Group, or Organization to be addressed over the
                    Personal Data Network. Peer of persona.ttl and context.ttl."""@en .


#################################################################
#    Identity Hierarchy
#################################################################

identity:PDNidentifier rdf:type owl:Class ;
    rdfs:subClassOf <https://purl.org/cco/ont00000958> ;  # Information Content Entity
    rdfs:label "Mee Identity"@en ;
    rdfs:comment "Root class for all kinds of identities that Mia can communicate with over the internet using Personal Data Network protocols."@en .

identity:Individual rdf:type owl:Class ;
    rdfs:subClassOf identity:PDNidentifier ;
    rdfs:label "Individual"@en ;
    rdfs:comment "An identifier of a human Mia user."@en .

identity:Group rdf:type owl:Class ;
    rdfs:subClassOf identity:PDNidentifier ;
    rdfs:label "Group"@en ;
    rdfs:comment "An identifier of a group of Mia users."@en .

identity:Organization rdf:type owl:Class ;
    rdfs:subClassOf identity:PDNidentifier ;
    rdfs:label "Organization"@en ;
    rdfs:comment "An identifier of an organization (company, government agency, non-profit, etc.)."@en .

