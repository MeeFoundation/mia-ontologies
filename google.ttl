@prefix : <http://www.example.org/mee#> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix cco: <https://purl.org/cco/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://www.example.org/mee> .

<http://www.example.org/mee/google> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona> ;
    dc:date "2026-05-25"^^xsd:date ;
    owl:versionInfo "Version 1.0.0 - Alice Walker's Google persona (Gmail)"@en ;
    rdfs:label "Alice Walker - Google Persona"@en ;
    rdfs:comment """Alice Walker's Google whoness — representing her in the context of her
                    Google account. Correlated from :Alice_Walker-Self in self.ttl.

                    Email: awalker@gmail.com"""@en .


#################################################################
#    Alice Walker - Google Persona
#################################################################

:Alice_Walker-Google rdf:type owl:NamedIndividual ,
                              persona:Persona ,
                              persona:Company ;
    rdfs:label "Alice Walker (Google)"@en ;
    rdfs:comment "Alice Walker's persona in the context of her Google account."@en ;

    <https://purl.org/cco/ont00001879> [  # designated by → Email
        rdf:type cco:ent00000024 ;
        <https://purl.org/cco/ont00001765> "awalker@gmail.com"
    ] .
