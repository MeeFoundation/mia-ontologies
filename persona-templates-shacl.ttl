@prefix : <http://www.example.org/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix cco: <https://purl.org/cco/> .
@prefix persona: <http://mee.foundation/ontologies/persona#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

<http://www.example.org/shapes/persona-templates> rdf:type owl:Ontology ;
    owl:imports <http://mee.foundation/ontologies/persona-templates> ;
    dc:date "2026-06-15"^^xsd:date ;
    owl:versionInfo "Version 1.0.4 - DriversLicenseShape: add IssuingJurisdiction and hasPhoto"@en ;
    rdfs:label "Persona Templates SHACL Validation Shapes"@en ;
    rdfs:comment """SHACL shapes for persona subtypes defined in persona-templates.ttl.
                    Imported by persona-shacl.ttl so a single -shapesfile covers everything."""@en .



#################################################################
#  JSContactCard Persona
#  Required: OrganizationName (1..1); at least one of Email or TelephoneNumber
#  Optional: all name components, OrganizationUnit, JobTitle, addresses,
#             online services, anniversaries, personalInfo, photo
#################################################################

:JSContactCardShape
    a sh:NodeShape ;
    sh:targetClass persona:JSContactCard ;
    sh:message "JSContactCard Persona validation: OrganizationName required, at least one email or phone required, max 1 per name/org component."@en ;

    # ── Name components (max 1 each) ────────────────────────────────────────
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000001 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one FullName."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000002 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one GivenName."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000004 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one FamilyName."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000003 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one AdditionalName (middle name)."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000058 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one Surname2 (maternal surname)."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000057 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one HonorificPrefix (Title)."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000005 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one generational Suffix."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000006 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one AlternateName."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ont00000990 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one Nickname."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class persona:Credential ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one post-nominal Credential."@en
    ] ;

    # ── Birthdate (max 1) ───────────────────────────────────────────────────
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000046 ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one Birthdate."@en
    ] ;

    # ── Organization fields (OrganizationName required; others max 1) ────────
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000047 ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard must have exactly one OrganizationName."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class persona:OrganizationUnit ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one OrganizationUnit."@en
    ] ;
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class persona:JobTitle ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A JSContactCard may have at most one JobTitle."@en
    ] ;

    # ── Contact channel (at least one required) ─────────────────────────────
    sh:or (
        [ sh:property [ sh:path <https://purl.org/cco/ont00001879> ; sh:qualifiedValueShape [ sh:class cco:ent00000024 ] ; sh:qualifiedMinCount 1 ] ]
        [ sh:property [ sh:path <https://purl.org/cco/ont00001879> ; sh:qualifiedValueShape [ sh:class cco:ent00000023 ] ; sh:qualifiedMinCount 1 ] ]
    ) .
    # ── Multi-valued channels (no upper bound) ──────────────────────────────
    # EmailAddress (ent00000024), TelephoneNumber (ent00000023),
    # USPostalAddress (ent00000010), OnlineServiceAccount (ont00000033),
    # WebURL (persona:WebURL), Anniversary (via persona:hasAnniversary),
    # PersonalInfo (via persona:hasPersonalInfo), Photo (via persona:hasPhoto)
    # — no sh:qualifiedMaxCount constraint; JSContact allows multiples.


#################################################################
#  DriversLicense Persona
#  Required: FullName (1..1) OR (GivenName 1..1 + FamilyName 1..1)
#            DateOfBirth (ent00000046, 1..1)
#            DriversLicenseNumber (persona:DriversLicenseNumber, 1..1)
#            ExpirationDateIdentifier (ent00000054, 1..1)
#  Optional: AdditionalName (ent00000003, 0..1), PostalAddress (ent00000010, 0..1)
#            IssuingJurisdiction (persona:IssuingJurisdiction, 0..1)
#            Photo (persona:hasPhoto, 0..1)
#################################################################

:DriversLicenseShape
    a sh:NodeShape ;
    sh:targetClass persona:DriversLicense ;
    sh:message "DriversLicense Persona validation: name, date of birth, license number, and expiration date are required."@en ;

    # ── Name: FullName OR (GivenName + FamilyName) ───────────────────────────
    sh:or (
        [
            sh:property [
                sh:path <https://purl.org/cco/ont00001879> ;
                sh:qualifiedValueShape [ sh:class cco:ent00000001 ] ;
                sh:qualifiedMinCount 1 ;
                sh:message "A DriversLicense Persona must be designated by a FullName, OR provide GivenName + FamilyName."@en
            ]
        ]
        [
            sh:and (
                [
                    sh:property [
                        sh:path <https://purl.org/cco/ont00001879> ;
                        sh:qualifiedValueShape [ sh:class cco:ent00000002 ] ;
                        sh:qualifiedMinCount 1 ;
                        sh:message "If no FullName is provided, a DriversLicense Persona must have at least one GivenName."@en
                    ]
                ]
                [
                    sh:property [
                        sh:path <https://purl.org/cco/ont00001879> ;
                        sh:qualifiedValueShape [ sh:class cco:ent00000004 ] ;
                        sh:qualifiedMinCount 1 ;
                        sh:message "If no FullName is provided, a DriversLicense Persona must have at least one FamilyName."@en
                    ]
                ]
            )
        ]
    ) ;

    # ── Required: DateOfBirth, LicenseNumber, ExpirationDate ─────────────────
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000046 ] ;  # Birthdate
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A DriversLicense Persona must have exactly one DateOfBirth."@en
    ] ;

    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class persona:DriversLicenseNumber ] ;
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A DriversLicense Persona must have exactly one DriversLicenseNumber."@en
    ] ;

    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000054 ] ;  # ExpirationDateIdentifier
        sh:qualifiedMinCount 1 ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A DriversLicense Persona must have exactly one ExpirationDateIdentifier."@en
    ] ;

    # ── Optional fields ──────────────────────────────────────────────────────
    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000003 ] ;  # AdditionalName
        sh:qualifiedMaxCount 1 ;
        sh:message "A DriversLicense Persona may have at most one AdditionalName."@en
    ] ;

    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class cco:ent00000010 ] ;  # USPostalAddress
        sh:qualifiedMaxCount 1 ;
        sh:message "A DriversLicense Persona may have at most one residential address."@en
    ] ;

    sh:property [
        sh:path <https://purl.org/cco/ont00001879> ;
        sh:qualifiedValueShape [ sh:class persona:IssuingJurisdiction ] ;
        sh:qualifiedMaxCount 1 ;
        sh:message "A DriversLicense Persona may have at most one IssuingJurisdiction."@en
    ] ;

    sh:property [
        sh:path persona:hasPhoto ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:message "A DriversLicense Persona may have at most one photo."@en
    ] .
